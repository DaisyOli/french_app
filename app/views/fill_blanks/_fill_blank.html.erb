<div id="fill-blank-<%= fill_blank.id %>" style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
  <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px;">
    <div style="display:flex; align-items:center; gap:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--ink-soft);">
      <i class="bi bi-dash-square" style="color:var(--info);"></i> Exercice à trous
    </div>
    <%= form_with url: update_order_activity_fill_blank_path(@activity, fill_blank), method: :patch,
          html: { style: "display:flex; align-items:center; gap:4px;" } do |form| %>
      <%= form.number_field :display_order, min: 1, value: fill_blank.display_order,
            title: "Ordre d'affichage",
            style: "width:52px; padding:4px 6px; border:1.5px solid var(--line); border-radius:6px; font-family:'DM Mono',monospace; font-size:0.8rem; text-align:center;" %>
      <%= form.submit "✓", style: "border:1.5px solid var(--brand-bright); background:var(--brand-tint); color:var(--brand-deep); border-radius:6px; padding:4px 9px; cursor:pointer; font-weight:700;" %>
    <% end %>
  </div>

  <div style="margin-bottom:12px;">
    <div style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-faint); margin-bottom:6px;">Texte à trous</div>
    <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.92rem; color:var(--ink); white-space:pre-wrap;"><%= fill_blank.text_with_numbered_blanks.html_safe %></div>
  </div>

  <div style="display:flex; gap:8px; margin-bottom:14px;">
    <button type="button" class="toggle-form" data-target="form-fill-blank-<%= fill_blank.id %>" title="Modifier l'exercice"
            style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--brand-bright); background:var(--surface); color:var(--brand-deep); cursor:pointer;">
      <i class="bi bi-pencil"></i>
    </button>
    <%= button_to activity_fill_blank_path(@activity, fill_blank), method: :delete,
          form: { data: { turbo_confirm: "Supprimer cet exercice à trous ?" } },
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--error-border); background:var(--error-tint); color:var(--error-deep); cursor:pointer;" do %>
      <i class="bi bi-trash"></i>
    <% end %>
  </div>

  <div id="form-fill-blank-<%= fill_blank.id %>" style="display:none; margin-bottom:14px; padding-bottom:14px; border-bottom:1px solid var(--line-soft);">
    <%= form_with model: fill_blank, url: activity_fill_blank_path(@activity, fill_blank), method: :patch do |form| %>
      <%= form.text_area :conteúdo, rows: 4, placeholder: "Utilisez ___ pour marquer les trous.\n\nEx: Le chat ___ sur la table et le chien ___ dans le jardin.",
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.76rem; color:var(--ink-faint); margin:6px 0 0;">Utilisez <strong>___</strong> (trois tirets bas) pour marquer les trous dans le texte.</p>
      <div style="display:flex; gap:8px; margin-top:10px;">
        <%= form.submit "Enregistrer", style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
        <button type="button" onclick="document.getElementById('form-fill-blank-<%= fill_blank.id %>').style.display='none'"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
          Annuler
        </button>
      </div>
    <% end %>
  </div>

  <div style="padding-left:14px; border-left:2px solid var(--line-soft);">
    <div style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-faint); margin-bottom:8px;">Réponses des trous</div>
    <% if fill_blank.blanks.any? %>
      <div style="display:flex; flex-direction:column; gap:8px;">
        <% fill_blank.blanks.order(:position).each do |blank| %>
          <%= render blank, fill_blank: fill_blank %>
        <% end %>
      </div>
    <% else %>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-faint); margin:0;">Aucun trou trouvé. Modifiez le texte et utilisez ___ pour créer des trous.</p>
    <% end %>
  </div>
</div>
