<% content_for :head do %>
  <title>Mes activités · Practice-FR</title>
<% end %>

<div style="max-width:1100px; margin:0 auto; padding:28px 16px 60px;">

  <%# Header — "Nouvelle activité"/"Inviter un étudiant" já vivem na navbar, sem duplicar aqui %>
  <div style="margin-bottom:20px;">
    <%= link_to teacher_dashboard_path,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:var(--ink-soft); text-decoration:none; display:inline-flex; align-items:center; gap:4px; margin-bottom:6px;" do %>
      <i class="bi bi-arrow-left"></i> Tableau de bord
    <% end %>
    <h1 style="font-family:'Raleway',sans-serif; font-size:1.5rem; font-weight:800; color:var(--brand-deep); margin:0;">
      Mes activités
    </h1>
  </div>

  <%# Métricas %>
  <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:20px;">
    <div style="flex:1; min-width:150px; background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:14px 18px;">
      <div style="font-family:'Raleway',sans-serif; font-size:1.5rem; font-weight:800; color:var(--brand-deep);"><%= @activities.count %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:var(--ink-soft);">activités</div>
    </div>
    <div style="flex:1; min-width:150px; background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:14px 18px;">
      <div style="font-family:'Raleway',sans-serif; font-size:1.5rem; font-weight:800; color:var(--info);"><%= @activities.sum { |a| activity_exercise_count(a) } %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:var(--ink-soft);">questions</div>
    </div>
    <button type="button" onclick="toggleRatingsModal()"
            style="flex:1; min-width:150px; background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:14px 18px; text-align:left; cursor:pointer; font:inherit;">
      <div style="display:flex; align-items:center; justify-content:space-between;">
        <div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.5rem; font-weight:800; color:var(--action);"><%= @total_ratings %></div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:var(--ink-soft);">évaluations</div>
        </div>
        <% if @total_ratings > 0 %>
          <i class="bi bi-chevron-right" style="color:var(--ink-faint);"></i>
        <% end %>
      </div>
    </button>
  </div>

  <%# Busca e filtros — GET tradicional, sem JS, igual ao practice-br %>
  <%= form_with url: activities_path, method: :get,
        html: { style: "display:block;" } do %>
    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:14px 16px; margin-bottom:24px; display:flex; gap:10px; flex-wrap:wrap; align-items:flex-end;">
      <div style="flex:2; min-width:180px;">
        <label style="display:block; font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-faint); margin-bottom:6px;">Rechercher</label>
        <input type="text" name="search" value="<%= params[:search] %>" placeholder="Titre de l'activité..."
               style="width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; padding:9px 12px; border:1.5px solid var(--line); border-radius:9px; background:var(--surface); color:var(--ink);">
      </div>
      <div style="flex:1; min-width:130px;">
        <label style="display:block; font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-faint); margin-bottom:6px;">Niveau</label>
        <select name="nível" style="width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; padding:9px 12px; border:1.5px solid var(--line); border-radius:9px; background:var(--surface); color:var(--ink);">
          <option value="">Tous</option>
          <% %w[A1 A2 B1 B2 C1 C2].each do |level| %>
            <option value="<%= level %>" <%= 'selected' if params[:nível] == level %>><%= level %></option>
          <% end %>
        </select>
      </div>
      <div style="flex:1; min-width:150px;">
        <label style="display:block; font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-faint); margin-bottom:6px;">Trier par</label>
        <select name="sort" style="width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; padding:9px 12px; border:1.5px solid var(--line); border-radius:9px; background:var(--surface); color:var(--ink);">
          <option value="recent" <%= 'selected' if params[:sort].blank? || params[:sort] == 'recent' %>>Plus récentes</option>
          <option value="oldest" <%= 'selected' if params[:sort] == 'oldest' %>>Plus anciennes</option>
          <option value="title" <%= 'selected' if params[:sort] == 'title' %>>Titre (A-Z)</option>
        </select>
      </div>
      <div style="display:flex; gap:8px;">
        <button type="submit"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:9px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;">
          Filtrer
        </button>
        <% if params[:search].present? || params[:nível].present? || params[:sort].present? %>
          <%= link_to "Effacer", activities_path,
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 16px; border-radius:9px; text-decoration:none; background:var(--surface); color:var(--ink-soft); border:1.5px solid var(--line); display:inline-flex; align-items:center;" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Grid de atividades %>
  <% if @activities.any? %>
    <div class="activities-grid">
      <% @activities.each do |activity| %>
        <% m = cefr_colors(activity.nível) %>
        <% cover = activity_cover(activity) %>
        <div class="activity-card">
          <div class="activity-card-cover">
            <% if cover[:type] == :image %>
              <img src="<%= cover[:url] %>" alt="" loading="lazy">
            <% else %>
              <div style="width:100%; height:100%; background:linear-gradient(135deg, <%= m[:bg] %> 0%, color-mix(in srgb, <%= m[:border] %> 20%, transparent) 100%); display:flex; align-items:center; justify-content:center;">
                <i class="bi <%= cover[:icon] %>" style="font-size:2.6rem; color:<%= m[:border] %>; opacity:0.55;"></i>
              </div>
            <% end %>
          </div>

          <div style="padding:16px 18px; flex:1; display:flex; flex-direction:column;">
            <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:8px;">
              <div style="display:flex; align-items:center; gap:6px; flex-wrap:wrap;">
                <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; background:<%= m[:bg] %>; color:<%= m[:text] %>; border:1.5px solid <%= m[:border] %>; padding:3px 9px; border-radius:20px;">
                  <%= activity.nível %>
                </span>
                <% if activity.competência.present? %>
                  <% cm = competencia_colors(activity.competência) %>
                  <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; background:<%= cm[:bg] %>; color:<%= cm[:text] %>; border:1.5px solid <%= cm[:border] %>; padding:3px 9px; border-radius:20px;">
                    <%= cm[:emoji] %> <%= activity.competência %>
                  </span>
                <% else %>
                  <span style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; color:var(--ink-faint); border:1.5px dashed var(--line); padding:3px 9px; border-radius:20px;">
                    Compétence non définie
                  </span>
                <% end %>
              </div>
              <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.74rem; color:var(--ink-faint); white-space:nowrap;">
                <%= activity.created_at.strftime("%d/%m/%Y") %>
              </span>
            </div>

            <h3 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:var(--ink); margin:0 0 6px 0; line-height:1.35;">
              <%= activity.título %>
            </h3>

            <% if activity.texto.present? %>
              <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; color:var(--ink-soft); margin:0 0 12px 0; line-height:1.5; flex:1;">
                <%= truncate(activity.texto, length: 90) %>
              </p>
            <% else %>
              <div style="flex:1;"></div>
            <% end %>

            <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:12px;">
              <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:var(--ink-faint); display:flex; align-items:center; gap:4px;">
                <i class="bi bi-patch-question" style="color:<%= m[:border] %>;"></i>
                <%= activity_exercise_count(activity) %> question<%= activity_exercise_count(activity) == 1 ? '' : 's' %>
              </span>
              <% if activity.activity_ratings.any? %>
                <span style="font-family:'DM Mono',monospace; font-size:0.77rem; font-weight:700; color:var(--action); display:flex; align-items:center; gap:3px;">
                  <i class="bi bi-star-fill" style="font-size:0.68rem;"></i> <%= activity.average_rating %> (<%= activity.ratings_count %>)
                </span>
              <% end %>
            </div>

            <div style="display:flex; gap:8px; padding-top:12px; border-top:1px solid var(--line-soft);">
              <%= link_to activity,
                    style: "flex:1; text-align:center; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:700; padding:8px 10px; border-radius:9px; text-decoration:none; background:var(--paper); color:var(--ink-soft); border:1.5px solid var(--line);" do %>
                <i class="bi bi-eye"></i> Voir
              <% end %>
              <%= link_to edit_activity_path(activity),
                    style: "flex:1; text-align:center; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:700; padding:8px 10px; border-radius:9px; text-decoration:none; background:var(--paper); color:var(--ink-soft); border:1.5px solid var(--line);" do %>
                <i class="bi bi-pencil"></i> Modifier
              <% end %>
              <%= button_to activity_path(activity), method: :delete,
                    form: { data: { turbo_confirm: "Archiver cette activité ?" }, style: "flex:1;" },
                    style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:700; padding:8px 10px; border-radius:9px; border:1.5px solid var(--error-border); background:var(--error-tint); color:var(--error-deep); cursor:pointer;" do %>
                <i class="bi bi-archive"></i> Archiver
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% elsif params[:search].present? || params[:nível].present? %>
    <div style="text-align:center; background:var(--surface); border:1px dashed var(--line); border-radius:18px; padding:48px 20px;">
      <span style="font-size:2rem; display:block; margin-bottom:10px;">🔍</span>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; color:var(--ink-soft); font-size:0.92rem; margin:0 0 12px;">
        Aucune activité ne correspond à ces filtres.
      </p>
      <%= link_to "Effacer les filtres", activities_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--brand);" %>
    </div>
  <% else %>
    <div style="text-align:center; background:var(--brand-mist); border:2px dashed var(--brand-soft); border-radius:18px; padding:48px 20px;">
      <span style="font-size:2.6rem; display:block; margin-bottom:10px;">🥐</span>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; color:var(--ink-soft); font-size:0.92rem; margin:0 0 16px;">
        <strong style="color:var(--brand-deep);">Vous n'avez pas encore d'activité…</strong><br>
        Créez la première pour vos étudiants.
      </p>
      <%= link_to "+ Nouvelle activité", new_activity_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:11px 24px; border-radius:999px; text-decoration:none; display:inline-flex; align-items:center; gap:8px; background:var(--brand); color:var(--surface);" %>
    </div>
  <% end %>
</div>

<%# Modal de avaliações %>
<div id="ratings-modal" style="display:none; position:fixed; inset:0; z-index:200; align-items:center; justify-content:center; background:rgba(0,0,0,0.4);">
  <div style="background:var(--surface); border-radius:18px; max-width:560px; width:92%; max-height:85vh; overflow-y:auto; padding:22px 24px;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
      <h3 style="font-family:'Raleway',sans-serif; font-size:1.15rem; font-weight:700; color:var(--brand-deep); margin:0;">
        <i class="bi bi-star-fill"></i> Avis de vos étudiants
      </h3>
      <button type="button" onclick="toggleRatingsModal()" style="background:none; border:none; font-size:1.2rem; color:var(--ink-faint); cursor:pointer;">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <% if @total_ratings > 0 %>
      <div style="display:flex; gap:10px; margin-bottom:20px;">
        <div style="flex:1; background:var(--paper-2); border-radius:12px; padding:12px; text-align:center;">
          <div style="font-family:'Raleway',sans-serif; font-size:1.3rem; font-weight:800; color:var(--brand-deep);"><%= @total_ratings %></div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; color:var(--ink-soft);">évaluations</div>
        </div>
        <div style="flex:1; background:var(--paper-2); border-radius:12px; padding:12px; text-align:center;">
          <div style="font-family:'Raleway',sans-serif; font-size:1.3rem; font-weight:800; color:var(--action);"><%= @average_rating_overall %></div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; color:var(--ink-soft);">moyenne</div>
        </div>
        <div style="flex:1; background:var(--paper-2); border-radius:12px; padding:12px; text-align:center;">
          <div style="font-family:'Raleway',sans-serif; font-size:1.3rem; font-weight:800; color:var(--info);"><%= @activities_with_ratings.count %></div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; color:var(--ink-soft);">activités évaluées</div>
        </div>
      </div>

      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.04em; margin-bottom:10px;">
        Dernières évaluations
      </div>
      <% @recent_ratings.each do |rating| %>
        <div style="padding:10px 0; border-bottom:1px solid var(--line-soft);">
          <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:4px;">
            <span style="font-family:'Plus Jakarta Sans',sans-serif; font-weight:600; font-size:0.85rem; color:var(--ink);"><%= truncate(rating.activity.título, length: 40) %></span>
            <span style="color:var(--action); font-size:0.78rem;"><%= "★" * rating.stars %><span style="color:var(--line);"><%= "★" * (5 - rating.stars) %></span></span>
          </div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.74rem; color:var(--ink-faint); margin-bottom:2px;">
            <%= rating.student.email.split('@').first %> · <%= rating.formatted_date %>
          </div>
          <% if rating.comment.present? %>
            <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-soft); font-style:italic; margin:4px 0 0;">"<%= rating.comment %>"</p>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div style="text-align:center; padding:24px 8px;">
        <span style="font-size:1.8rem; display:block; margin-bottom:8px;">⭐</span>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; color:var(--ink-soft); font-size:0.88rem; margin:0;">
          Aucune évaluation pour l'instant.
        </p>
      </div>
    <% end %>
  </div>
</div>

<script>
  function toggleRatingsModal() {
    const modal = document.getElementById('ratings-modal');
    modal.style.display = (modal.style.display === 'none' || modal.style.display === '') ? 'flex' : 'none';
  }
  document.addEventListener('click', function(e) {
    const modal = document.getElementById('ratings-modal');
    if (e.target === modal) toggleRatingsModal();
  });
</script>
