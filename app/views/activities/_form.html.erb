<div style="background:var(--surface); border:1px solid var(--line); border-radius:16px; padding:28px 26px;">

  <div style="margin-bottom:24px;">
    <h1 style="font-family:'Raleway',sans-serif; font-size:1.4rem; font-weight:800; color:var(--brand-deep); margin:0 0 6px;">
      <%= activity.new_record? ? "Nouvelle activité" : "Modifier l'activité" %>
    </h1>
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink-soft); margin:0;">
      <%= activity.new_record? ? "Créez une nouvelle activité pour vos étudiants." : "Modifiez les informations de cette activité." %>
    </p>
  </div>

  <%= form_with(model: activity) do |form| %>
    <% if activity.errors.any? %>
      <div style="background:var(--error-tint); border:1.5px solid var(--error); border-radius:12px; padding:14px 18px; margin-bottom:20px;">
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-weight:700; font-size:0.88rem; color:var(--error-deep); margin-bottom:6px;">
          <%= pluralize(activity.errors.count, "erreur") %>
        </div>
        <ul style="margin:0; padding-left:18px;">
          <% activity.errors.full_messages.each do |message| %>
            <li style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--error-deep);"><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div style="margin-bottom:20px;">
      <%= form.label :título, "Titre", style: "display:block; font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-soft); margin-bottom:8px;" %>
      <%= form.text_field :título, style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
    </div>

    <div style="margin-bottom:20px;">
      <span style="display:block; font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-soft); margin-bottom:8px;">Niveau</span>
      <div style="display:flex; flex-wrap:wrap; gap:8px;">
        <% ['A1', 'A2', 'B1', 'B2', 'C1', 'C2'].each do |level| %>
          <% m = cefr_colors(level) %>
          <%= form.radio_button :nível, level, id: "activity_nivel_#{level}", class: "level-radio" %>
          <label for="activity_nivel_<%= level %>" class="level-pill" style="--pill-bg:<%= m[:bg] %>; --pill-text:<%= m[:text] %>; --pill-border:<%= m[:border] %>;">
            <%= level %>
          </label>
        <% end %>
      </div>
    </div>

    <div style="margin-bottom:20px;">
      <span style="display:block; font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-soft); margin-bottom:8px;">Compétence</span>
      <div style="display:flex; flex-wrap:wrap; gap:8px;">
        <% %w[CO CE EE].each do |code| %>
          <% m = competencia_colors(code) %>
          <%= form.radio_button :competência, code, id: "activity_competencia_#{code}", class: "level-radio" %>
          <label for="activity_competencia_<%= code %>" class="level-pill" style="--pill-bg:<%= m[:bg] %>; --pill-text:<%= m[:text] %>; --pill-border:<%= m[:border] %>;">
            <%= m[:emoji] %> <%= code %>
          </label>
        <% end %>
      </div>
    </div>

    <div style="margin-bottom:28px;">
      <%= form.label :texto, "Description", style: "display:block; font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-soft); margin-bottom:8px;" %>
      <%= form.text_area :texto, rows: 5, style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink); resize:vertical;" %>
    </div>

    <div style="display:flex; align-items:center; gap:12px;">
      <%= form.submit activity.new_record? ? "Créer l'activité" : "Mettre à jour l'activité",
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:11px 24px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
      <%= link_to "Annuler", activities_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:11px 24px; border-radius:999px; text-decoration:none; background:var(--surface); color:var(--ink-soft); border:1.5px solid var(--line);" %>
    </div>
  <% end %>
</div>
