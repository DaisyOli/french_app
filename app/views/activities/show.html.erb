<% content_for :head do %>
  <title><%= @activity.título %> · Practice-FR</title>
<% end %>

<% m = cefr_colors(@activity.nível) %>
<div style="max-width:760px; margin:0 auto; padding:28px 16px 60px;">

  <%# En-tête %>
  <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:24px;">
    <h1 style="font-family:'Raleway',sans-serif; font-size:1.5rem; font-weight:800; color:var(--brand-deep); margin:0;"><%= @activity.título %></h1>
    <div style="display:flex; align-items:center; gap:6px; flex-shrink:0;">
      <span style="font-family:'DM Mono',monospace; font-size:0.78rem; font-weight:700; background:<%= m[:bg] %>; color:<%= m[:text] %>; border:1.5px solid <%= m[:border] %>; padding:3px 12px; border-radius:20px;">
        <%= @activity.nível %>
      </span>
      <% if @activity.competência.present? %>
        <% cm = competencia_colors(@activity.competência) %>
        <span style="font-family:'DM Mono',monospace; font-size:0.78rem; font-weight:700; background:<%= cm[:bg] %>; color:<%= cm[:text] %>; border:1.5px solid <%= cm[:border] %>; padding:3px 12px; border-radius:20px;">
          <%= cm[:emoji] %> <%= @activity.competência %>
        </span>
      <% else %>
        <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; color:var(--ink-faint); border:1.5px dashed var(--line); padding:3px 12px; border-radius:20px;">
          Compétence non définie
        </span>
      <% end %>
    </div>
  </div>

  <%# Description %>
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:20px;">
    <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.04em; margin-bottom:10px;">
      <i class="bi bi-info-circle"></i> <%= t('common.description') %>
    </div>
    <% if @activity.texto.present? %>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); white-space:pre-wrap; margin-bottom:10px;"><%= @activity.texto %></div>
    <% else %>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink-faint); margin:0 0 10px;"><%= t('common.no_description') %></p>
    <% end %>
    <button type="button" class="toggle-form" data-target="form-texto" title="<%= t('common.edit_description') %>"
            style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--brand-bright); background:var(--surface); color:var(--brand-deep); cursor:pointer;">
      <i class="bi bi-pencil"></i>
    </button>

    <div id="form-texto" style="display:none; margin-top:14px; padding-top:14px; border-top:1px solid var(--line-soft);">
      <%= form_with model: @activity, url: activity_path(@activity), method: :patch do |form| %>
        <%= form.text_area :texto, rows: 5,
              style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
        <div style="display:flex; gap:8px; margin-top:10px;">
          <%= form.submit t('common.save'), style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
          <button type="button" onclick="document.getElementById('form-texto').style.display='none'"
                  style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
            <%= t('helpers.actions.cancel') %>
          </button>
        </div>
      <% end %>
    </div>
  </div>

  <%# Vidéo, image et texte libre sont des champs de l'Activity elle-même
      (pas des models séparés) — traités ici, à part du render polymorphique
      des exercices ci-dessous. %>
  <% if @activity.video_url.present? %>
    <div id="video-section" style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px;">
        <div style="display:flex; align-items:center; gap:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--ink-soft);">
          <i class="bi bi-film" style="color:var(--brand);"></i> <%= t('common.video') %>
        </div>
        <%= form_with model: @activity, url: activity_path(@activity), method: :patch, html: { style: "display:flex; align-items:center; gap:4px;" } do |form| %>
          <%= form.number_field :video_order, min: 1,
                style: "width:52px; padding:4px 6px; border:1.5px solid var(--line); border-radius:6px; font-family:'DM Mono',monospace; font-size:0.8rem; text-align:center;" %>
          <%= form.submit "✓", style: "border:1.5px solid var(--brand-bright); background:var(--brand-tint); color:var(--brand-deep); border-radius:6px; padding:4px 9px; cursor:pointer; font-weight:700;" %>
        <% end %>
      </div>

      <%
        video_id = nil
        if @activity.video_url.include?('youtube.com/watch?v=')
          video_id = @activity.video_url.split('watch?v=').last.split('&').first
        elsif @activity.video_url.include?('youtu.be/')
          video_id = @activity.video_url.split('youtu.be/').last
        end
        embed_url = video_id ? "https://www.youtube.com/embed/#{video_id}" : @activity.video_url
      %>
      <div style="position:relative; width:100%; padding-bottom:56.25%; margin-bottom:12px; border-radius:10px; overflow:hidden;">
        <iframe src="<%= embed_url %>" allowfullscreen style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;"></iframe>
      </div>

      <div style="display:flex; gap:8px;">
        <button type="button" class="toggle-form" data-target="form-video" title="<%= t('common.edit_video') %>"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--brand-bright); background:var(--surface); color:var(--brand-deep); cursor:pointer;">
          <i class="bi bi-pencil"></i>
        </button>
        <%= button_to remove_video_activity_path(@activity), method: :delete,
              form: { data: { turbo_confirm: t('common.confirm_delete_video') } },
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--error-border); background:var(--error-tint); color:var(--error-deep); cursor:pointer;" do %>
          <i class="bi bi-trash"></i>
        <% end %>
      </div>

      <div id="form-video" style="display:none; margin-top:14px; padding-top:14px; border-top:1px solid var(--line-soft);">
        <%= form_with model: @activity, url: activity_path(@activity), method: :patch do |form| %>
          <%= form.text_field :video_url, placeholder: "https://www.youtube.com/watch?v=XXXX",
                style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
          <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.76rem; color:var(--ink-faint); margin:6px 0 0;">Lien YouTube. Ex : https://www.youtube.com/watch?v=XXXX ou https://youtu.be/XXXX</p>
          <div style="display:flex; gap:8px; margin-top:10px;">
            <%= form.submit t('common.save'), style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
            <button type="button" onclick="document.getElementById('form-video').style.display='none'"
                    style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
              <%= t('helpers.actions.cancel') %>
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @activity.imagem_url.present? %>
    <div id="image-section" style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px;">
        <div style="display:flex; align-items:center; gap:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--ink-soft);">
          <i class="bi bi-image" style="color:var(--brand);"></i> <%= t('common.image') %>
        </div>
        <%= form_with model: @activity, url: activity_path(@activity), method: :patch, html: { style: "display:flex; align-items:center; gap:4px;" } do |form| %>
          <%= form.number_field :imagem_order, min: 1,
                style: "width:52px; padding:4px 6px; border:1.5px solid var(--line); border-radius:6px; font-family:'DM Mono',monospace; font-size:0.8rem; text-align:center;" %>
          <%= form.submit "✓", style: "border:1.5px solid var(--brand-bright); background:var(--brand-tint); color:var(--brand-deep); border-radius:6px; padding:4px 9px; cursor:pointer; font-weight:700;" %>
        <% end %>
      </div>

      <img src="<%= @activity.imagem_url %>" alt="Image de l'activité" style="width:100%; border-radius:10px; margin-bottom:12px;">

      <div style="display:flex; gap:8px;">
        <button type="button" class="toggle-form" data-target="form-imagem" title="<%= t('common.edit_image') %>"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--brand-bright); background:var(--surface); color:var(--brand-deep); cursor:pointer;">
          <i class="bi bi-pencil"></i>
        </button>
        <%= button_to remove_image_activity_path(@activity), method: :delete,
              form: { data: { turbo_confirm: t('common.confirm_delete_image') } },
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--error-border); background:var(--error-tint); color:var(--error-deep); cursor:pointer;" do %>
          <i class="bi bi-trash"></i>
        <% end %>
      </div>

      <div id="form-imagem" style="display:none; margin-top:14px; padding-top:14px; border-top:1px solid var(--line-soft);">
        <%= form_with model: @activity, url: activity_path(@activity), method: :patch do |form| %>
          <%= form.text_field :imagem_url, placeholder: "https://exemple.com/image.jpg",
                style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
          <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.76rem; color:var(--ink-faint); margin:6px 0 0;">Lien direct vers une image.</p>
          <div style="display:flex; gap:8px; margin-top:10px;">
            <%= form.submit t('common.save'), style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
            <button type="button" onclick="document.getElementById('form-imagem').style.display='none'"
                    style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
              <%= t('helpers.actions.cancel') %>
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @activity.texte.present? %>
    <div id="texte-section" style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px;">
        <div style="display:flex; align-items:center; gap:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--ink-soft);">
          <i class="bi bi-file-text" style="color:var(--brand);"></i> <%= t('common.texte') %>
        </div>
        <%= form_with model: @activity, url: activity_path(@activity), method: :patch, html: { style: "display:flex; align-items:center; gap:4px;" } do |form| %>
          <%= form.number_field :texte_order, min: 1,
                style: "width:52px; padding:4px 6px; border:1.5px solid var(--line); border-radius:6px; font-family:'DM Mono',monospace; font-size:0.8rem; text-align:center;" %>
          <%= form.submit "✓", style: "border:1.5px solid var(--brand-bright); background:var(--brand-tint); color:var(--brand-deep); border-radius:6px; padding:4px 9px; cursor:pointer; font-weight:700;" %>
        <% end %>
      </div>

      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); white-space:pre-wrap; margin-bottom:12px;"><%= @activity.texte %></div>

      <div style="display:flex; gap:8px;">
        <button type="button" class="toggle-form" data-target="form-texte" title="<%= t('common.edit_texte') %>"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--brand-bright); background:var(--surface); color:var(--brand-deep); cursor:pointer;">
          <i class="bi bi-pencil"></i>
        </button>
        <%= button_to remove_texte_activity_path(@activity), method: :delete,
              form: { data: { turbo_confirm: t('common.confirm_delete_texte') } },
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--error-border); background:var(--error-tint); color:var(--error-deep); cursor:pointer;" do %>
          <i class="bi bi-trash"></i>
        <% end %>
      </div>

      <div id="form-texte" style="display:none; margin-top:14px; padding-top:14px; border-top:1px solid var(--line-soft);">
        <%= form_with model: @activity, url: activity_path(@activity), method: :patch do |form| %>
          <%= form.text_area :texte, rows: 5, placeholder: t('common.texte_placeholder'),
                style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
          <div style="display:flex; gap:8px; margin-top:10px;">
            <%= form.submit t('common.save'), style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
            <button type="button" onclick="document.getElementById('form-texte').style.display='none'"
                    style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
              <%= t('helpers.actions.cancel') %>
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Exercices — render polymorphique: cada tipo resolve seu próprio
      partial (app/views/statements/_statement.html.erb etc.) a partir do
      nome da classe do objeto. Substitui o case/when de ~670 linhas que
      existia aqui antes do redesenho. %>
  <%= render @activity.ordered_elements %>

  <%# Ajouter un nouvel élément %>
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
    <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.04em; margin-bottom:12px;">
      <i class="bi bi-plus-circle"></i> <%= t('common.add_elements') %>
    </div>
    <div style="display:flex; flex-wrap:wrap; gap:8px;">
      <% unless @activity.video_url.present? %>
        <button type="button" class="toggle-form add-btn" data-target="form-video-add" title="<%= t('common.add_video') %>"><i class="bi bi-film"></i></button>
      <% end %>
      <% unless @activity.imagem_url.present? %>
        <button type="button" class="toggle-form add-btn" data-target="form-imagem-add" title="<%= t('common.add_image') %>"><i class="bi bi-image"></i></button>
      <% end %>
      <% unless @activity.texte.present? %>
        <button type="button" class="toggle-form add-btn" data-target="form-texte-add" title="<%= t('common.add_texte') %>"><i class="bi bi-file-text"></i></button>
      <% end %>
      <button type="button" class="toggle-form add-btn" data-target="form-new-statement" title="<%= t('common.add_statement') %>"><i class="bi bi-list-ul"></i></button>
      <button type="button" class="toggle-form add-btn" data-target="form-new-question" title="<%= t('common.add_question') %>"><i class="bi bi-question-circle"></i></button>
      <button type="button" class="toggle-form add-btn" data-target="form-new-fill-blank" title="Ajouter un exercice à trous"><i class="bi bi-dash-square"></i></button>
      <button type="button" class="toggle-form add-btn" data-target="form-new-sentence-ordering" title="Organiser les mots"><i class="bi bi-arrows-move"></i></button>
      <button type="button" class="toggle-form add-btn" data-target="form-new-paragraph-ordering" title="Organiser les phrases"><i class="bi bi-list-ol"></i></button>
      <button type="button" class="toggle-form add-btn" data-target="form-new-column-association" title="Associer colonnes"><i class="bi bi-diagram-3"></i></button>
      <button type="button" class="toggle-form add-btn" data-target="form-new-suggestion" title="<%= t('common.add_suggestion') %>"><i class="bi bi-lightbulb"></i></button>
    </div>
  </div>

  <div id="form-video-add" style="display:none; background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
    <%= form_with model: @activity, url: activity_path(@activity), method: :patch do |form| %>
      <%= form.text_field :video_url, placeholder: "https://www.youtube.com/watch?v=XXXX",
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.76rem; color:var(--ink-faint); margin:6px 0 0;">Lien YouTube. Ex : https://www.youtube.com/watch?v=XXXX ou https://youtu.be/XXXX</p>
      <div style="display:flex; gap:8px; margin-top:10px;">
        <%= form.submit t('common.save'), style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
        <button type="button" onclick="document.getElementById('form-video-add').style.display='none'"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
          <%= t('helpers.actions.cancel') %>
        </button>
      </div>
    <% end %>
  </div>

  <div id="form-imagem-add" style="display:none; background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
    <%= form_with model: @activity, url: activity_path(@activity), method: :patch do |form| %>
      <%= form.text_field :imagem_url, placeholder: "https://exemple.com/image.jpg",
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.76rem; color:var(--ink-faint); margin:6px 0 0;">Lien direct vers une image.</p>
      <div style="display:flex; gap:8px; margin-top:10px;">
        <%= form.submit t('common.save'), style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
        <button type="button" onclick="document.getElementById('form-imagem-add').style.display='none'"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
          <%= t('helpers.actions.cancel') %>
        </button>
      </div>
    <% end %>
  </div>

  <div id="form-texte-add" style="display:none; background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
    <%= form_with model: @activity, url: activity_path(@activity), method: :patch do |form| %>
      <%= form.text_area :texte, rows: 5, placeholder: t('common.texte_placeholder'),
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
      <div style="display:flex; gap:8px; margin-top:10px;">
        <%= form.submit t('common.save'), style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
        <button type="button" onclick="document.getElementById('form-texte-add').style.display='none'"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
          <%= t('helpers.actions.cancel') %>
        </button>
      </div>
    <% end %>
  </div>

  <div id="form-new-statement" style="display:none; background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
    <%= form_with model: [@activity, Statement.new], url: activity_statements_path(@activity) do |form| %>
      <%= form.text_area :conteúdo, rows: 3, placeholder: t('common.statement_placeholder'),
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
      <div style="display:flex; gap:8px; margin-top:10px;">
