<style>
  .add-btn {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.1rem;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1.5px solid var(--brand-bright);
    background: var(--surface);
    color: var(--brand-deep);
    cursor: pointer;
  }

  .highlight-new-element {
    animation: highlight-pulse 3s ease-out;
  }

  @keyframes highlight-pulse {
    0% { box-shadow: 0 0 0 3px var(--brand-bright); }
    100% { box-shadow: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.toggle-form').forEach(function (button) {
      button.addEventListener('click', function () {
        const target = document.getElementById(this.getAttribute('data-target'));
        if (!target) return;
        target.style.display = (target.style.display === 'none' || target.style.display === '') ? 'block' : 'none';
      });
    });
  });

  // Rola a tela até o elemento indicado por ?scroll_to= (usado depois de
  // criar/apagar exercícios) e destaca ele por 3s.
  function scrollToHighlightElement() {
    const scrollToId = new URLSearchParams(window.location.search).get('scroll_to');
    if (!scrollToId) return;

    const element = document.getElementById(scrollToId);
    if (!element) return;

    setTimeout(() => {
      element.scrollIntoView({ behavior: 'smooth', block: 'center' });
      element.classList.add('highlight-new-element');
      setTimeout(() => element.classList.remove('highlight-new-element'), 3000);
    }, 300);
  }

  document.addEventListener('DOMContentLoaded', scrollToHighlightElement);
  document.addEventListener('turbo:load', scrollToHighlightElement);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    setTimeout(scrollToHighlightElement, 100);
  }
</script>
