    function initializeTapToSwap() {
      document.querySelectorAll('.drag-drop-exercise[data-exercise-type="sentence"]').forEach(exercise => {
        setupTapToSwapGroup(exercise, '.draggable-word', {
          initial: "Touchez un mot puis un autre pour les échanger.",
          selected: "Touchez un autre mot pour l'échanger.",
          deselected: "Sélectionnez un mot pour commencer.",
          swapped: "Mot placé ! Touchez un autre mot pour continuer."
        });
      });

      document.querySelectorAll('.drag-drop-exercise[data-exercise-type="paragraph"]').forEach(exercise => {
        setupTapToSwapGroup(exercise, '.draggable-sentence', {
          initial: "Touchez une phrase puis une autre pour les échanger.",
          selected: "Touchez une autre phrase pour l'échanger.",
          deselected: "Sélectionnez une phrase pour commencer.",
          swapped: "Phrase placée ! Touchez une autre phrase pour continuer."
        });
      });
    }

    function setupTapToSwapGroup(exercise, itemSelector, messages) {
      let selected = null;
      const status = exercise.querySelector('.ordering-status');
      const setStatus = (msg) => { if (status) status.textContent = msg; };

      function clearSelection() {
        if (selected) selected.classList.remove('selected');
        selected = null;
      }

      function handleActivate(item) {
        if (exercise.classList.contains('disabled')) return;

        if (!selected) {
          selected = item;
          item.classList.add('selected');
          setStatus(messages.selected);
          return;
        }

        if (selected === item) {
          clearSelection();
          setStatus(messages.deselected);
          return;
        }

        const zoneA = selected.parentElement;
        const zoneB = item.parentElement;
        if (zoneA && zoneB && zoneA !== zoneB) {
          zoneA.appendChild(item);
          zoneB.appendChild(selected);
        }
        clearSelection();
        setStatus(messages.swapped);
      }

      exercise.querySelectorAll(itemSelector).forEach(item => {
        item.setAttribute('role', 'button');
        item.setAttribute('tabindex', '0');
        item.addEventListener('click', () => handleActivate(item));
        item.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            handleActivate(item);
          }
        });
      });

      setStatus(messages.initial);
    }

    // === FUNÇÕES PARA EXERCÍCIOS DE ASSOCIAÇÃO ===
    
    // Função para verificar associações de colunas
    function checkColumnAssociation(exercise) {
      const associationItems = exercise.querySelectorAll('.association-item[data-item-type="a"]');
      const totalPairs = associationItems.length;
      let correctConnections = 0;
      
      // Verificar cada item da coluna A
      associationItems.forEach(itemA => {
        const pairId = itemA.getAttribute('data-pair-id');
        const pointA = itemA.querySelector('.connection-point');
        
        // Encontrar se há conexão para este ponto
        const connectionLines = exercise.querySelectorAll('.connection-line');
        connectionLines.forEach(line => {
          const startPoint = line.getAttribute('data-start-point');
          const endPoint = line.getAttribute('data-end-point');
          const pointAId = pairId + '-a';
          const pointBId = pairId + '-b';
          
          // Verificar se a linha conecta os pontos corretos do mesmo par
          if ((startPoint === pointAId && endPoint === pointBId) || 
              (startPoint === pointBId && endPoint === pointAId)) {
            correctConnections++;
          }
        });
      });
      
      return correctConnections === totalPairs;
    }
    
