<script>
// Paginação do quiz — um exercício por vez (padrão da franquia; vanilla até o app ganhar Stimulus)
(function() {
  var steps = document.querySelectorAll('.quiz-step');
  if (!steps.length) return;
  var atual = 0, total = steps.length;
  var counter = document.getElementById('quiz-step-counter');
  var fill = document.getElementById('quiz-progress-fill');
  var prev = document.getElementById('quiz-prev-btn');
  var next = document.getElementById('quiz-next-btn');
  var back = document.getElementById('quiz-back-link');
  var submitSec = document.querySelector('.submit-section');

  function mostrar(n) {
    atual = Math.max(0, Math.min(n, total - 1));
    steps.forEach(function(s, i) { s.style.display = (i === atual) ? '' : 'none'; });
    if (counter) counter.textContent = (atual + 1) + ' sur ' + total;
    if (fill) fill.style.width = (((atual + 1) * 100) / total) + '%';
    if (back) back.style.display = (atual === 0) ? 'flex' : 'none';
    if (prev) prev.style.display = (atual === 0) ? 'none' : 'flex';
    if (next) next.style.display = (atual === total - 1) ? 'none' : 'flex';
    if (submitSec) submitSec.style.display = (atual === total - 1) ? '' : 'none';
    var col = document.querySelector('.quiz-exercise-col') || document.querySelector('.quiz-paper');
    if (col) col.scrollTop = 0;
  }
  if (prev) prev.addEventListener('click', function() { mostrar(atual - 1); });
  if (next) next.addEventListener('click', function() { mostrar(atual + 1); });
  mostrar(0);

  // material colapsável no mobile
  var toggle = document.getElementById('quiz-material-toggle');
  var materialCol = document.getElementById('quiz-material-col');
  if (toggle && materialCol) {
    toggle.addEventListener('click', function() { materialCol.classList.toggle('collapsed'); });
  }

  // modo resultado: quiz sai de cena quando o placar aparece
  var results = document.getElementById('results-container');
  var outer = document.querySelector('.quiz-outer');
  if (results && outer) {
    new MutationObserver(function() {
      var visivel = results.style.display !== 'none';
      outer.classList.toggle('fr-results-mode', visivel);
      if (visivel) window.scrollTo({ top: 0 });
    }).observe(results, { attributes: true, attributeFilter: ['style'] });
    var showAnswers = document.getElementById('show-answers');
    if (showAnswers) showAnswers.addEventListener('click', function() {
      outer.classList.remove('fr-results-mode');
      window.scrollTo({ top: 0 });
    });
  }
})();
</script>
