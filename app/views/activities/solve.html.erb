    background: var(--brand-bright);
    box-shadow: 0 0 8px var(--brand-glow);
  }

  .connection-point.selected {
    animation: pulse 1s infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }

  .association-exercise.disabled {
    opacity: 0.7;
    pointer-events: none;
  }

  .association-exercise.disabled .connection-point {
    cursor: not-allowed;
  }

  /* === BOTÕES COM DESIGN MODERNO === */
  .btn-submit {
    background: var(--action);
    color: var(--surface);
    border: none;
    border-radius: 12px;
    padding: 0.8rem 1.8rem;
    font-size: 0.95rem;
    font-weight: 700;
    font-family: 'Plus Jakarta Sans', sans-serif;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-submit:hover {
    background: var(--action-hover);
  }

  .btn-back {
    background: rgba(255, 255, 255, 0.9);
    color: var(--primary-dark);
    border: 2px solid rgba(30, 61, 89, 0.2);
    border-radius: 12px;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    backdrop-filter: blur(10px);
  }

  .btn-back:hover {
    background: var(--primary-dark);
    color: white;
    text-decoration: none;
    transform: translateX(-4px);
    box-shadow: 0 8px 24px rgba(30, 61, 89, 0.3);
  }

  /* === EFEITOS DE FEEDBACK === */
  .success-header {
    background: var(--brand-deep) !important;
  }

  .score-circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: var(--paper);
    border: 4px solid var(--action);
    color: var(--brand-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    box-shadow: 0 8px 24px rgba(21, 128, 61, 0.4);
    animation: scoreReveal 0.8s ease-out;
  }

  @keyframes scoreReveal {
    0% {
      transform: scale(0) rotate(180deg);
      opacity: 0;
    }
    50% {
      transform: scale(1.2) rotate(90deg);
    }
    100% {
      transform: scale(1) rotate(0deg);
      opacity: 1;
    }
  }

  /* === ANIMAÇÕES DINÂMICAS === */
  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .content-card {
    animation: fadeInUp 0.6s ease-out;
  }

  .content-card:nth-child(1) { animation-delay: 0.1s; }
  .content-card:nth-child(2) { animation-delay: 0.2s; }
  .content-card:nth-child(3) { animation-delay: 0.3s; }
  .content-card:nth-child(4) { animation-delay: 0.4s; }
  .content-card:nth-child(5) { animation-delay: 0.5s; }

  /* === RESPONSIVIDADE === */
  @media (max-width: 768px) {
    .activity-title {
      font-size: 2rem;
    }
    
    .card-body {
      padding: 1.5rem;
    }
    
    .alternative-label {
      padding: 0.75rem 1rem;
    }
    
    .btn-submit {
      width: 100%;
      margin: 1.5rem 0;
    }
  }

  /* === PERSONALIZAÇÃO POR TIPO DE CARD === */
  
  /* Cartões de texto/statement com borda lateral colorida */
  .text-card,
  .statement-card {
    border-left: 6px solid var(--accent-indigo);
  }

  /* Cartões de sugestão com design especial */
  .suggestion-card {
    border-left: 6px solid var(--suggestion-color);
    background: var(--brand-mist);
  }

  /* Cartões de vídeo e imagem com bordas arredondadas especiais */
  .video-card,
  .image-card {
    border: 2px solid transparent;
    background: var(--surface); border-color: var(--brand-soft);
  }

     /* === MELHORIAS NOS INPUTS === */
     .fill-blank-input {
    border: 1.5px solid var(--brand-bright);
    border-radius: 7px;
    padding: 2px 10px;
    font-size: 0.88rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: all 0.2s ease;
    background: var(--brand-mist);
    color: var(--ink);
  }

  .fill-blank-input:focus {
    border-color: var(--brand);
    box-shadow: 0 1px 6px var(--brand-glow);
    background: var(--surface);
    outline: none;
  }

   /* === ESTILOS PARA EXERCÍCIOS DE ORDENAÇÃO (toque pra trocar) === */

   /* === LAYOUT SIMPLIFICADO DE UMA COLUNA === */
   .drag-drop-exercise[data-exercise-type="paragraph"] {
     display: block;
     max-width: 800px;
     margin: 0 auto;
   }

   /* Construtores */
   .sentence-builder {
     background: var(--surface-2);
     border: 1.5px solid var(--line);
     border-radius: 16px;
     padding: 1.5rem;
   }

   .paragraph-builder {
     background: var(--surface-2);
     border: 1.5px solid var(--line);
     border-radius: 12px;
     padding: 1rem;
     min-height: fit-content;
     display: flex;
     flex-direction: column;
   }

   /* Zonas de drop */
  .drop-zones {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
    min-height: 60px;
    align-items: flex-start;
  }
  
  .drop-zone {
     background: var(--surface);
     border: 2px dashed var(--line);
     border-radius: 8px;
    min-width: 80px;
    min-height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: all 0.3s ease;
    padding: 0.25rem;
  }
  
  .drop-zone .position-number {
    position: absolute;
    top: -8px;
    left: -8px;
     background: var(--paper-2);
    color: var(--ink-faint);
    border: 1px solid var(--line);
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
  }
  
  .drop-zone:has(.draggable-word) {
    background: transparent;
    border: 2px solid transparent;
  }
  
   /* Zonas de drop para parágrafos */
  .paragraph-drop-zones {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
    flex: 1;
    min-height: fit-content;
  }
  
  .paragraph-drop-zone {
     background: var(--violet-tint);
     border: 2px dashed var(--violet-border);
    border-radius: 8px;
    min-height: 40px;
    display: flex;
    align-items: center;
    position: relative;
    transition: all 0.3s ease;
    padding: 0.4rem;
  }

  .paragraph-drop-zone .position-number {
    position: absolute;
    top: -10px;
    left: 0.75rem;
     background: var(--info-purple);
    color: var(--surface);
    padding: 0.2rem 0.4rem;
    border-radius: 10px;
    font-size: 0.7rem;
    font-weight: 600;
  }
  
  .paragraph-drop-zone .drop-content {
    width: 100%;
  }
  
  .paragraph-drop-zone:has(.draggable-sentence) {
    background: transparent;
    border: 2px solid transparent;
    min-height: auto;
    padding: 0.25rem;
  }
  
  /* Zonas sempre têm frases - remover placeholder */

   /* === ASSOCIAÇÃO DE COLUNAS — LAYOUT (encaixado no card estreito) === */
   .association-container {
     display: flex;
     align-items: flex-start;
     gap: 1.25rem;
     margin: 1.5rem 0;
     position: relative;
   }

   .association-column {
     flex: 1;
     min-width: 0;
   }

   .column-items {
     display: flex;
     flex-direction: column;
     gap: 0.75rem;
   }

   .association-column.column-a .association-item {
     padding-right: 1.75rem;
   }

   .association-column.column-b .association-item {
     padding-left: 1.75rem;
   }

   .association-column.column-a .connection-point {
     position: absolute;
     right: -8px;
     top: 50%;
     transform: translateY(-50%);
   }

   .association-column.column-b .connection-point {
     position: absolute;
     left: -8px;
     top: 50%;
     transform: translateY(-50%);
   }

   .connection-zone {
     position: absolute;
     top: 0;
     left: 50%;
     transform: translateX(-50%);
     width: 1.5rem;
     height: 100%;
     pointer-events: none;
   }

   .connection-svg {
     position: absolute;
     top: 0;
     left: 0;
   }

   /* Sem "stroke" aqui de propósito: cada linha ganha a cor do seu par
      via JS (setAttribute), e uma regra CSS pisaria nisso e pintaria
      todas as linhas da mesma cor. */
   .connection-line {
     stroke-width: 3;
     fill: none;
     stroke-linecap: round;
     transition: all 0.3s ease;
   }

   /* === FEEDBACK DE CORES === */
   .text-success {
     color: var(--success-green) !important;
   }

   .text-danger {
     color: var(--error) !important;
   }

   .text-warning {
     color: var(--warning-orange) !important;
   }

   .bg-success {
     background-color: rgba(21, 128, 61, 0.1) !important;
     border-color: var(--success-green) !important;
   }

   .bg-danger {
     background-color: rgba(239, 68, 68, 0.1) !important;
     border-color: var(--error) !important;
   }

   /* === INSTRUÇÕES E TEXTOS === */
   .instruction-text {
     color: var(--ink-faint);
     font-size: 0.8rem;
     font-weight: 400;
     font-style: italic;
     margin-bottom: 1rem;
     text-align: left;
     line-height: 1.6;
   }

   .exercise-title {
     color: var(--primary-dark);
     font-family: 'Raleway', sans-serif;
     font-size: 1.3rem;
     font-weight: 600;
     margin-bottom: 1rem;
     text-align: center;
   }

   .question-text {
     font-size: 0.92rem;
     line-height: 1.65;
     color: var(--ink);
     margin-bottom: 10px;
     font-weight: 400;
   }

   /* === MEDIA CONTENT === */
   .video-container {
     position: relative;
     width: 100%;
     height: 0;
     padding-bottom: 56.25%; /* 16:9 aspect ratio */
     border-radius: 16px;
     overflow: hidden;
     box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
   }

   .video-container iframe {
     position: absolute;
     top: 0;
     left: 0;
     width: 100%;
     height: 100%;
     border: none;
   }

   .image-container {
     text-align: center;
   }

   .activity-image {
     max-width: 100%;
     height: auto;
     border-radius: 16px;
     box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
   }

   .text-content {
     font-size: 1.1rem;
     line-height: 1.7;
     color: var(--primary-dark);
   }

   /* === SUBMIT E RESULTS === */
   .submit-section {
     text-align: center;
     margin: 2rem 0;
   }

     .results-card .card-header.success-header {
    background: var(--brand-deep) !important;
    color: var(--surface) !important;
  }

   .score-display {
     display: flex;
     align-items: center;
     gap: 1.5rem;
     margin-bottom: 2rem;
   }

   .score-details {
     flex: 1;
   }

   .score-details p {
     margin: 0 0 0.5rem;
     font-size: 1.1rem;
     color: var(--primary-dark);
     font-weight: 600;
   }

   .score-details p:last-child {
     color: var(--ink-faint);
     font-weight: 400;
     font-size: 1rem;
   }

   /* === ACTION BUTTONS === */
   .action-buttons {
     display: flex;
     gap: 1rem;
     justify-content: center;
     flex-wrap: wrap;
     margin-top: 1.5rem;
   }

   .btn-secondary {
     background: var(--brand);
     color: white;
     border: none;
     padding: 0.75rem 1.5rem;
     border-radius: 12px;
     font-weight: 600;
     display: inline-flex;
     align-items: center;
     gap: 0.5rem;
     transition: all 0.3s ease;
     text-decoration: none;
   }

   .btn-secondary:hover {
     transform: translateY(-2px);
     box-shadow: 0 8px 24px rgba(178, 69, 99, 0.4);
     color: white;
     text-decoration: none;
   }

   .btn-outline {
     background: transparent;
     color: var(--primary-blue);
     border: 2px solid var(--primary-blue);
     padding: 0.75rem 1.5rem;
     border-radius: 12px;
     font-weight: 600;
     display: inline-flex;
     align-items: center;
     gap: 0.5rem;
     transition: all 0.3s ease;
     text-decoration: none;
   }

   .btn-outline:hover {
     background: var(--primary-blue);
     color: white;
     transform: translateY(-2px);
     text-decoration: none;
   }

   /* === NAVIGATION === */
   .navigation-section {
     text-align: center;
     margin-top: 2rem;
     padding-top: 2rem;
     border-top: 1px solid rgba(255, 255, 255, 0.3);
   }

   /* === PRESERVE FORMATTING === */
   .preserve-format {
     white-space: pre-line;
   }

  /* === DRAG AND DROP EXERCISES === */
  
  .sentence-content {
    font-weight: 500;
    line-height: 1.4;
  }

  /* === FEEDBACK COLORS === */
  .text-success {
    color: var(--success-border) !important;
  }
  
  .text-warning {
    color: var(--warning-border) !important;
  }
  
  .text-danger {
    color: var(--error) !important;
  }
  
  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .drag-drop-exercise[data-exercise-type="paragraph"] {
      max-width: 100%;
      margin: 0;
    }
    
    .paragraph-builder {
      padding: 0.75rem;
    }
    
    .drop-zones {
      justify-content: center;
    }
    
    .drop-zone {
      min-width: 70px;
      min-height: 45px;
    }
    
    .draggable-word {
      font-size: 0.85rem;
      padding: 0.4rem 0.8rem;
    }
    
    .draggable-sentence {
      padding: 0.6rem 0.8rem;
      font-size: 0.85rem;
    }
    
    .paragraph-drop-zone {
      min-height: 35px;
      padding: 0.3rem;
    }
    
    .drag-drop-exercise {
      padding: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .sentence-builder,
    .paragraph-builder {
      padding: 0.6rem;
    }
    
    .drop-zone {
      min-width: 60px;
      min-height: 40px;
    }
    
    .draggable-word {
      font-size: 0.8rem;
      padding: 0.3rem 0.6rem;
    }
    
    .draggable-sentence {
      padding: 0.5rem 0.6rem;
      font-size: 0.8rem;
      margin-bottom: 0.4rem;
    }
    
    .paragraph-drop-zone {
      min-height: 32px;
      padding: 0.25rem;
    }
    
    .paragraph-drop-zone .position-number {
      font-size: 0.65rem;
      padding: 0.15rem 0.3rem;
    }
  }

  /* === FEEDBACK DETAILED === */
  #question-feedback .card {
    border: none;
    border-radius: 12px;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  #question-feedback .card.border-success {
    border-left: 4px solid var(--success-border);
  }
  
  /* Responsive para exercícios de associação — empilha as colunas e some
     com a zona de conexão (as linhas não fazem sentido empilhadas) */
  @media (max-width: 640px) {
    .association-container {
      flex-direction: column;
      gap: 1.75rem;
    }

    .connection-zone {
      display: none;
    }

    .connection-point {
      width: 14px;
      height: 14px;
    }
  }

  #question-feedback .card.border-danger {
    border-left: 4px solid var(--error-border);
  }

  #question-feedback .card-header {
    border-radius: 0;
    font-weight: 600;
  }

  #question-feedback .card-header.bg-success {
    background: var(--success-tint) !important;
    color: var(--success-deep) !important;
  }

  #question-feedback .card-header.bg-danger {
    background: var(--error-tint) !important;
    color: var(--error-deep) !important;
  }

  #question-feedback .badge.bg-success {
    background: var(--success) !important;
    color: var(--surface) !important;
  }

  #question-feedback .badge.bg-danger {
    background: var(--error) !important;
    color: var(--surface) !important;
  }

  #question-feedback .card-header {
    font-size: 0.78rem;
    padding: 9px 16px;
  }

  #question-feedback .card-body {
    font-size: 0.88rem;
    padding: 14px 16px;
  }

  #question-feedback .card {
    border: 1px solid var(--line) !important;
  }

  /* a letrinha no feedback é texto corrido, não bolinha flex */
  #question-feedback .alternative-letter {
    display: inline;
    width: auto;
    height: auto;
    background: none;
    padding: 0;
    color: inherit;
    font-weight: 700;
  }

  /* Estilos removidos - usando novos estilos coloridos */

  .fill-blank-text {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--ink);
    font-weight: 500;
  }

  .blank-input::placeholder {
    color: var(--ink-faint);
    font-style: italic;
    font-weight: 400;
  }

  .blank-input:disabled {
    background-color: var(--surface-2);
    border-color: var(--line);
    color: var(--ink-faint);
    cursor: not-allowed;
  }

  /* === PRESERVE FORMAT === */
  .preserve-format {
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  /* === RESPONSIVIDADE === */
  @media (max-width: 768px) {
    .solve-activity {
      padding: 1rem 0.5rem;
    }

    .activity-header-card {
      padding: 1.5rem;
    }

    .activity-title {
      font-size: 2rem;
    }

    .content-section {
      padding: 1.5rem;
    }

    .content-card .card-body {
      padding: 1rem;
    }

    .score-display {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }

    .action-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn-secondary,
    .btn-outline,
    .btn-submit,
    .btn-back {
      width: 100%;
      max-width: 300px;
    }

    .alternative-label {
      font-size: 0.95rem;
    }

    .alternative-letter {
      width: 24px;
      height: 24px;
      font-size: 0.8rem;
    }

    .blank-input {
      min-width: 50px;
      max-width: 100px;
      font-size: 0.85rem;
      padding: 0.2rem 0.3rem;
      margin: 0 0.05rem;
    }

    .fill-blank-text {
      font-size: 0.92rem;
      line-height: 1.6;
    }
  }

  @media (max-width: 480px) {
    .activity-title {
      font-size: 1.75rem;
    }

    .content-card .card-header {
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
    }

    .alternative-option {
      padding: 0.75rem;
    }
  }

  /* === ESTILOS DO MODAL DE AVALIAÇÃO === */
  .rating-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(5px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .rating-modal.show {
    opacity: 1;
  }

  .rating-modal-content {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    max-width: 500px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    transform: translateY(-30px);
    transition: transform 0.3s ease;
  }

  .rating-modal.show .rating-modal-content {
    transform: translateY(0);
  }

  .rating-modal-header h3 {
    color: var(--brand-deep);
    margin-bottom: 0.5rem;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .rating-modal-header h3 i {
    color: var(--action-bright);
  }

  .rating-modal-header p {
    color: var(--ink-faint);
    margin-bottom: 1.5rem;
  }

  .stars-container {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .stars-label {
    color: var(--ink-soft);
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .stars-rating {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .stars-rating i {
    font-size: 2rem;
    color: var(--line);
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 0.25rem;
    border-radius: 50%;
  }

  .stars-rating i:hover,
  .stars-rating i.active {
    color: var(--action-bright);
    transform: scale(1.1);
  }

  .stars-rating i:hover {
    background: rgba(255, 215, 0, 0.1);
  }

  .comment-container {
    margin-bottom: 1.5rem;
  }

  .comment-label {
    display: block;
    color: var(--ink-soft);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .rating-textarea {
    width: 100%;
    min-height: 100px;
    border: 2px solid var(--line);
    border-radius: 12px;
    padding: 1rem;
    font-family: inherit;
    resize: vertical;
    transition: border-color 0.2s ease;
  }

  .rating-textarea:focus {
    outline: none;
    border-color: var(--brand-bright);
    box-shadow: 0 0 0 3px rgba(178, 69, 99, 0.1);
  }

  .character-count {
    text-align: right;
    font-size: 0.85rem;
    color: var(--ink-faint);
    margin-top: 0.25rem;
  }

  .rating-modal-footer {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
  }

  .btn-modal-skip {
    background: transparent;
    border: 2px solid var(--line);
    color: var(--ink-faint);
    padding: 0.75rem 1.5rem;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
    font-weight: 500;
  }

