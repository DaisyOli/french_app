<div id="question-<%= question.id %>" style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
  <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px;">
    <div style="display:flex; align-items:center; gap:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--ink-soft);">
      <i class="bi bi-question-circle" style="color:var(--brand);"></i> Question
    </div>
    <%= form_with url: update_order_activity_question_path(@activity, question), method: :patch,
          html: { style: "display:flex; align-items:center; gap:4px;" } do |form| %>
      <%= form.number_field :display_order, min: 1, value: question.display_order,
            title: "Ordre d'affichage",
            style: "width:52px; padding:4px 6px; border:1.5px solid var(--line); border-radius:6px; font-family:'DM Mono',monospace; font-size:0.8rem; text-align:center;" %>
      <%= form.submit "✓", style: "border:1.5px solid var(--brand-bright); background:var(--brand-tint); color:var(--brand-deep); border-radius:6px; padding:4px 9px; cursor:pointer; font-weight:700;" %>
    <% end %>
  </div>

  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-weight:700; font-size:0.95rem; color:var(--ink); white-space:pre-wrap; margin-bottom:12px;"><%= question.conteúdo %></div>

  <div style="display:flex; gap:8px; margin-bottom:14px;">
    <button type="button" class="toggle-form" data-target="form-question-<%= question.id %>" title="Modifier"
            style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--brand-bright); background:var(--surface); color:var(--brand-deep); cursor:pointer;">
      <i class="bi bi-pencil"></i>
    </button>
    <%= button_to activity_question_path(@activity, question), method: :delete,
          form: { data: { turbo_confirm: t('common.confirm_delete') } },
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--error-border); background:var(--error-tint); color:var(--error-deep); cursor:pointer;" do %>
      <i class="bi bi-trash"></i>
    <% end %>
  </div>

  <div id="form-question-<%= question.id %>" style="display:none; margin-bottom:14px; padding-bottom:14px; border-bottom:1px solid var(--line-soft);">
    <%= form_with model: question, url: activity_question_path(@activity, question), method: :patch do |form| %>
      <%= form.text_area :conteúdo, rows: 3,
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
      <div style="display:flex; gap:8px; margin-top:10px;">
        <%= form.submit "Enregistrer", style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
        <button type="button" onclick="document.getElementById('form-question-<%= question.id %>').style.display='none'"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
          Annuler
        </button>
      </div>
    <% end %>
  </div>

  <div style="padding-left:14px; border-left:2px solid var(--line-soft);">
    <% if question.alternatives.any? %>
      <ul style="list-style:none; margin:0 0 10px; padding:0; display:flex; flex-direction:column; gap:8px;">
        <% question.alternatives.each do |alternative| %>
          <%= render alternative, question: question %>
        <% end %>
      </ul>
    <% else %>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-faint); margin:0 0 10px;"><%= t('common.no_alternatives') %></p>
    <% end %>

    <button type="button" class="toggle-form" data-target="form-new-alternative-<%= question.id %>" title="<%= t('common.add_alternative') %>"
            style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px dashed var(--brand-bright); background:var(--surface); color:var(--brand-deep); cursor:pointer;">
      <i class="bi bi-plus"></i> Alternative
    </button>

    <div id="form-new-alternative-<%= question.id %>" style="display:none; margin-top:10px;">
      <%= form_with model: [@activity, question, Alternative.new], url: activity_question_alternatives_path(@activity, question) do |form| %>
        <%= form.text_area :conteúdo, rows: 2, placeholder: t('common.alternative_placeholder'),
              style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
        <label style="display:flex; align-items:center; gap:6px; margin-top:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--ink-soft);">
          <%= form.check_box :correta %> <%= t('common.alternative_correct') %>
        </label>
        <div style="display:flex; gap:8px; margin-top:10px;">
          <%= form.submit "Enregistrer", style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
          <button type="button" onclick="document.getElementById('form-new-alternative-<%= question.id %>').style.display='none'"
                  style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
            Annuler
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
