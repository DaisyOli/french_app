<div id="paragraph-ordering-<%= paragraph_ordering.id %>" style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
  <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px;">
    <div style="display:flex; align-items:center; gap:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--ink-soft);">
      <i class="bi bi-list-ol" style="color:var(--violet);"></i> Organisation de phrases
    </div>
    <%= form_with url: update_order_activity_paragraph_ordering_path(@activity, paragraph_ordering), method: :patch,
          html: { style: "display:flex; align-items:center; gap:4px;" } do |form| %>
      <%= form.number_field :display_order, min: 1, value: paragraph_ordering.display_order,
            title: "Ordre d'affichage",
            style: "width:52px; padding:4px 6px; border:1.5px solid var(--line); border-radius:6px; font-family:'DM Mono',monospace; font-size:0.8rem; text-align:center;" %>
      <%= form.submit "✓", style: "border:1.5px solid var(--brand-bright); background:var(--brand-tint); color:var(--brand-deep); border-radius:6px; padding:4px 9px; cursor:pointer; font-weight:700;" %>
    <% end %>
  </div>

  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); margin-bottom:12px;">
    <% if paragraph_ordering.titre.present? %>
      <div><strong>Titre :</strong> <%= paragraph_ordering.titre %></div>
    <% end %>
    <% if paragraph_ordering.instruction.present? %>
      <div><strong>Instructions :</strong> <%= paragraph_ordering.instruction %></div>
    <% end %>
  </div>

  <div style="display:flex; gap:8px; margin-bottom:14px;">
    <button type="button" class="toggle-form" data-target="form-paragraph-ordering-<%= paragraph_ordering.id %>" title="Modifier l'exercice"
            style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--brand-bright); background:var(--surface); color:var(--brand-deep); cursor:pointer;">
      <i class="bi bi-pencil"></i>
    </button>
    <%= button_to activity_paragraph_ordering_path(@activity, paragraph_ordering), method: :delete,
          form: { data: { turbo_confirm: "Supprimer cet exercice d'organisation de phrases ?" } },
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--error-border); background:var(--error-tint); color:var(--error-deep); cursor:pointer;" do %>
      <i class="bi bi-trash"></i>
    <% end %>
  </div>

  <div id="form-paragraph-ordering-<%= paragraph_ordering.id %>" style="display:none; margin-bottom:14px; padding-bottom:14px; border-bottom:1px solid var(--line-soft);">
    <%= form_with model: paragraph_ordering, url: activity_paragraph_ordering_path(@activity, paragraph_ordering), method: :patch do |form| %>
      <%= form.text_field :titre, placeholder: "Titre de l'exercice",
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink); margin-bottom:8px;" %>
      <%= form.text_area :instruction, rows: 2, placeholder: "Instructions pour l'étudiant",
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
      <div style="display:flex; gap:8px; margin-top:10px;">
        <%= form.submit "Enregistrer", style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
        <button type="button" onclick="document.getElementById('form-paragraph-ordering-<%= paragraph_ordering.id %>').style.display='none'"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
          Annuler
        </button>
      </div>
    <% end %>
  </div>

  <div style="padding-left:14px; border-left:2px solid var(--line-soft);">
    <div style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-faint); margin-bottom:8px;">Phrases à organiser</div>
    <% if paragraph_ordering.paragraph_sentences.any? %>
      <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:10px;">
        <% paragraph_ordering.paragraph_sentences.order(:correct_position).each do |sentence| %>
          <%= render sentence, paragraph_ordering: paragraph_ordering %>
        <% end %>
      </div>
    <% else %>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-faint); margin:0 0 10px;">Aucune phrase ajoutée. Ajoutez des phrases pour créer l'exercice.</p>
    <% end %>

    <button type="button" class="toggle-form" data-target="form-new-sentence-<%= paragraph_ordering.id %>" title="Ajouter une phrase"
            style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px dashed var(--brand-bright); background:var(--surface); color:var(--brand-deep); cursor:pointer;">
      <i class="bi bi-plus"></i> Phrase
    </button>

    <div id="form-new-sentence-<%= paragraph_ordering.id %>" style="display:none; margin-top:10px;">
      <%= form_with model: [paragraph_ordering, ParagraphSentence.new], url: activity_paragraph_ordering_paragraph_sentences_path(@activity, paragraph_ordering) do |form| %>
        <%= form.text_area :sentence, rows: 2, placeholder: "Tapez une phrase complète",
              style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
        <div style="display:flex; gap:8px; margin-top:10px;">
          <%= form.submit "Ajouter", style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
          <button type="button" onclick="document.getElementById('form-new-sentence-<%= paragraph_ordering.id %>').style.display='none'"
                  style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
            Annuler
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
