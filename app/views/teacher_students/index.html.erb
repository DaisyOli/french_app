<% content_for :head do %>
  <title>Mes étudiants · Practice-FR</title>
<% end %>

<div style="max-width:1100px; margin:0 auto; padding:28px 16px 60px;">

  <div style="margin-bottom:20px;">
    <%= link_to teacher_dashboard_path,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:var(--ink-soft); text-decoration:none; display:inline-flex; align-items:center; gap:4px; margin-bottom:6px;" do %>
      <i class="bi bi-arrow-left"></i> Tableau de bord
    <% end %>
    <h1 style="font-family:'Raleway',sans-serif; font-size:1.5rem; font-weight:800; color:var(--brand-deep); margin:0;">
      Mes étudiants
    </h1>
  </div>

  <%= form_with url: teacher_students_path, method: :get,
        html: { style: "background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:14px 16px; margin-bottom:24px; display:flex; gap:10px; flex-wrap:wrap; align-items:flex-end;" } do %>
    <div style="flex:1; min-width:200px;">
      <label style="display:block; font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-faint); margin-bottom:6px;">Rechercher</label>
      <input type="text" name="search" value="<%= params[:search] %>" placeholder="Email de l'étudiant..."
             style="width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; padding:9px 12px; border:1.5px solid var(--line); border-radius:9px; background:var(--surface); color:var(--ink);">
    </div>
    <button type="submit"
            style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:9px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;">
      Filtrer
    </button>
    <% if params[:search].present? %>
      <%= link_to "Effacer", teacher_students_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 16px; border-radius:9px; text-decoration:none; background:var(--surface); color:var(--ink-soft); border:1.5px solid var(--line); display:inline-flex; align-items:center;" %>
    <% end %>
  <% end %>

  <% if @students.any? %>
    <div class="activities-grid">
      <% @students.each do |student| %>
        <% m = student.nível.present? ? cefr_colors(student.nível) : nil %>
        <%= link_to teacher_student_path(student), style: "text-decoration:none; color:inherit;" do %>
          <div class="activity-card">
            <div style="padding:18px; flex:1; display:flex; flex-direction:column;">
              <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px;">
                <div style="width:44px; height:44px; border-radius:50%; background:var(--brand-tint); color:var(--brand-deep); display:flex; align-items:center; justify-content:center; font-family:'Raleway',sans-serif; font-weight:700; font-size:1.05rem; flex-shrink:0;">
                  <%= student.email.first.upcase %>
                </div>
                <div style="flex:1; min-width:0;">
                  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-weight:700; font-size:0.92rem; color:var(--ink); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    <%= student.email %>
                  </div>
                  <% if m %>
                    <span style="display:inline-block; margin-top:3px; font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; background:<%= m[:bg] %>; color:<%= m[:text] %>; border:1.5px solid <%= m[:border] %>; padding:1px 7px; border-radius:20px;">
                      <%= student.nível %>
                    </span>
                  <% else %>
                    <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; color:var(--ink-faint);">⚠️ sans niveau</span>
                  <% end %>
                </div>
              </div>

              <div style="display:flex; gap:14px; padding-top:12px; border-top:1px solid var(--line-soft);">
                <div style="flex:1; text-align:center;">
                  <div style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:800; color:var(--brand-deep);"><%= @attempts_count[student.id] || 0 %></div>
                  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.68rem; color:var(--ink-faint);">tentatives</div>
                </div>
                <div style="flex:1; text-align:center;">
                  <% avg = @average_scores[student.id] %>
                  <div style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:800; color:var(--info);"><%= avg ? "#{avg.round}%" : "—" %></div>
                  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.68rem; color:var(--ink-faint);">moyenne</div>
                </div>
                <div style="flex:1; text-align:center;">
                  <% last = @last_activity[student.id] %>
                  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; color:var(--ink-soft);"><%= last ? last.strftime("%d/%m") : "—" %></div>
                  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.68rem; color:var(--ink-faint);">dernière activité</div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% elsif params[:search].present? %>
    <div style="text-align:center; background:var(--surface); border:1px dashed var(--line); border-radius:18px; padding:48px 20px;">
      <span style="font-size:2rem; display:block; margin-bottom:10px;">🔍</span>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; color:var(--ink-soft); font-size:0.92rem; margin:0 0 12px;">
        Aucun étudiant ne correspond à cette recherche.
      </p>
      <%= link_to "Effacer la recherche", teacher_students_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--brand);" %>
    </div>
  <% else %>
    <div style="text-align:center; background:var(--brand-mist); border:2px dashed var(--brand-soft); border-radius:18px; padding:48px 20px;">
      <span style="font-size:2.6rem; display:block; margin-bottom:10px;">🥐</span>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; color:var(--ink-soft); font-size:0.92rem; margin:0;">
        Aucun étudiant invité pour l'instant.
      </p>
    </div>
  <% end %>
</div>
