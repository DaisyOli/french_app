<%# Navbar da franquia Practice — estrutura portada do practice-br. %>
<%# FR tem DOIS escopos Devise: user (professora) e student (aluno).   %>
<nav id="main-navbar"
     class="navbar px-4"
     style="position:fixed; top:0; left:0; right:0; z-index:100; background:var(--brand-deep); min-height:56px;">

  <%# Logo — leva à casa de quem está logado %>
  <div class="navbar-start">
    <% home_path = if student_signed_in?
                     student_dashboard_path
                   elsif user_signed_in?
                     activities_path
                   else
                     root_path
                   end %>
    <%= link_to home_path do %>
      <%= image_tag "practice-fr-logo-horizontal-mono-light.svg",
            alt: "Practice-FR",
            class: "hidden sm:block",
            style: "height:28px;" %>
      <%= image_tag "practice-fr-logo-mark-mono-light.svg",
            alt: "Practice-FR",
            class: "block sm:hidden",
            style: "height:28px;" %>
    <% end %>
  </div>

  <%# Ações — lado direito %>
  <div class="navbar-end gap-2 sm:gap-4">

    <% if user_signed_in? && !student_signed_in? %>
      <%# ---- Professora ---- %>
      <% if current_user.admin? %>
        <%# Admin convida aluno OU professor — dropdown com as duas opções. %>
        <div class="dropdown hidden sm:block">
          <label tabindex="0"
                 class="flex items-center whitespace-nowrap px-4 py-1.5 rounded-lg text-sm font-semibold no-underline cursor-pointer"
                 style="background:var(--surface); color:var(--brand-deep); border:1.5px solid var(--brand-tint-2); font-family:'Plus Jakarta Sans',sans-serif;">
            <i class="bi bi-envelope" style="margin-right:6px;"></i>Inviter
          </label>
          <ul tabindex="0"
              class="dropdown-content menu menu-sm shadow-lg z-50 mt-2 p-2 rounded-xl"
              style="background:var(--surface); border:1px solid var(--line); min-width:220px;">
            <li><%= link_to "Inviter un étudiant", new_student_invitation_path,
                      style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; font-weight:600; color:var(--ink);" %></li>
            <li><%= link_to "Inviter un professeur", new_user_invitation_path,
                      style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; font-weight:600; color:var(--ink);" %></li>
          </ul>
        </div>
      <% else %>
        <%= link_to new_student_invitation_path,
              class: "hidden sm:inline-flex items-center whitespace-nowrap px-4 py-1.5 rounded-lg text-sm font-semibold no-underline",
              style: "background:var(--surface); color:var(--brand-deep); border:1.5px solid var(--brand-tint-2); font-family:'Plus Jakarta Sans',sans-serif; text-decoration:none;" do %>
          <i class="bi bi-envelope" style="margin-right:6px;"></i>Inviter un étudiant
        <% end %>
      <% end %>

      <% if current_user.admin? %>
        <%= link_to admin_root_path,
              class: "hidden sm:inline-flex items-center whitespace-nowrap px-4 py-1.5 rounded-lg text-sm font-semibold no-underline",
              style: "background:var(--surface); color:var(--brand-deep); border:1.5px solid var(--brand-tint-2); font-family:'Plus Jakarta Sans',sans-serif; text-decoration:none;" do %>
          <i class="bi bi-speedometer2" style="margin-right:6px;"></i>Panneau Admin
        <% end %>
      <% end %>

      <%= link_to "+ Nouvelle activité", new_activity_path,
            class: "hidden sm:inline-flex items-center whitespace-nowrap px-4 py-1.5 rounded-lg text-sm font-semibold text-white no-underline",
            style: "background:var(--brand-bright); font-family:'Plus Jakarta Sans',sans-serif; text-decoration:none;" %>

      <% teacher_mobile_links = [["+ Nouvelle activité", new_activity_path, "var(--brand)"],
                                 ["Inviter un étudiant", new_student_invitation_path, "var(--brand)"]]
         if current_user.admin?
           teacher_mobile_links << ["Inviter un professeur", new_user_invitation_path, "var(--brand)"]
           teacher_mobile_links << ["Panneau Admin", admin_root_path, "var(--brand-deep)"]
         end %>
      <%= render "shared/navbar_dropdown",
            role_label: current_user.admin? ? "PROFESSEURE · ADMIN" : "PROFESSEURE",
            display_name: "Daisy 🌼",
            avatar_letter: "D",
            avatar_gradient: "var(--action), var(--action-bright)",
            mobile_links: teacher_mobile_links,
            sign_out_path: destroy_user_session_path %>

    <% elsif student_signed_in? %>
      <%# ---- Aluno: troféus da Daisy em pills da franquia (visíveis em qualquer largura) ---- %>
      <div class="flex items-center gap-1 px-2 sm:px-3 py-1 rounded-full"
           style="background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.2); font-family:'DM Mono',monospace; font-size:0.75rem; color:var(--action-bright);">
        🏆 <%= current_student.completed_activities.count %>
      </div>
      <div class="flex items-center gap-1 px-2 sm:px-3 py-1 rounded-full"
           style="background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.2); font-family:'DM Mono',monospace; font-size:0.75rem; color:var(--action-bright);">
        <%= current_student.current_trophy[:icon] %> <%= current_student.current_streak %>
      </div>

      <%= link_to "Activités", student_activities_path,
            class: "hidden sm:inline-flex items-center whitespace-nowrap px-4 py-1.5 rounded-lg text-sm font-semibold text-white no-underline",
            style: "background:var(--brand-bright); font-family:'Plus Jakarta Sans',sans-serif; text-decoration:none;" %>

      <%= render "shared/navbar_dropdown",
            role_label: "ÉLÈVE",
            display_name: current_student.name.presence || current_student.email,
            avatar_letter: (current_student.name.presence || current_student.email).first.upcase,
            avatar_gradient: "var(--info), var(--info-deep)",
            mobile_links: [["Tableau de bord", student_dashboard_path, "var(--brand)"],
                           ["Activités", student_activities_path, "var(--brand)"]],
            sign_out_path: destroy_student_session_path %>

    <% else %>
      <%# ---- Visitante: entradas de professora e aluno ----          %>
      <%# Botões fantasma no desktop; no mobile viram um menu compacto %>
      <%# pra não estourar a largura fixa de 50% da navbar-end.        %>
      <div class="hidden sm:flex items-center gap-2 sm:gap-4">
        <%= link_to t('devise.shared.links.sign_in_student'), new_student_session_path, class: "nav-ghost-btn" %>
        <%= link_to t('devise.shared.links.sign_in_teacher'), new_user_session_path, class: "nav-ghost-btn" %>
      </div>

      <div class="dropdown dropdown-end sm:hidden">
        <label tabindex="0"
               class="btn btn-ghost btn-circle"
               style="width:36px; height:36px; min-height:0; padding:0; color:var(--brand-tint-2);">
          <i class="bi bi-person-circle" style="font-size:1.4rem;"></i>
        </label>
        <ul tabindex="0"
            class="dropdown-content menu menu-sm shadow-lg z-50 mt-2 p-2 rounded-xl"
            style="background:var(--surface); border:1px solid var(--line); min-width:200px;">
          <li><%= link_to t('devise.shared.links.sign_in_student'), new_student_session_path,
                    style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; font-weight:600; color:var(--ink);" %></li>
          <li><%= link_to t('devise.shared.links.sign_in_teacher'), new_user_session_path,
                    style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; font-weight:600; color:var(--ink);" %></li>
        </ul>
      </div>
    <% end %>
  </div>
</nav>
