<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-theme="practice-fr">
  <head>
    <%# Título padrão só quando a view não define o próprio via
        content_for :head (achado: as duas tags <title> coexistiam e o
        navegador sempre usava esta aqui, ignorando o título de cada
        página — nenhuma das 18 views que já usam content_for :head pra
        isso estava realmente funcionando). %>
    <% unless content_for?(:head) %>
      <title><%= t('common.app_name') %></title>
    <% end %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%# theme-color é uma das exceções onde hex é permitido (espelha --brand-deep) %>
    <meta name="theme-color" content="#5C1630">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Fontes da franquia Practice: Raleway + Plus Jakarta Sans + DM Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons: só os ícones (bi-*), usados no app inteiro — sem
         relação com o framework CSS/JS do Bootstrap, que foi removido daqui
         quando a última view (activities/show.html.erb) saiu do Bootstrap. -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <!-- Favicon: o símbolo vetorial — nítido em qualquer tamanho -->
    <link rel="icon" type="image/svg+xml" href="<%= asset_path 'practice-fr-logo-mark-color.svg' %>">

    <%= yield :head %>
  </head>

  <body>
    <% unless content_for?(:hide_navbar) %>
      <%= render 'shared/navbar' %>
      <div style="height:56px;"></div>
    <% end %>

    <%= render 'layouts/flash' %>

    <%= yield %>
  </body>
</html>
