<% content_for :head do %>
  <title>Inviter un professeur · Practice-FR</title>
<% end %>

<div style="max-width:480px; margin:0 auto; padding:28px 16px 60px;">
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:16px; padding:28px 26px;">

    <div style="text-align:center; margin-bottom:22px;">
      <div style="width:56px; height:56px; border-radius:50%; background:var(--brand-tint); display:flex; align-items:center; justify-content:center; margin:0 auto 14px;">
        <i class="bi bi-mortarboard" style="font-size:1.4rem; color:var(--brand-deep);"></i>
      </div>
      <h1 style="font-family:'Raleway',sans-serif; font-size:1.3rem; font-weight:800; color:var(--brand-deep); margin:0 0 6px;">
        Inviter un professeur
      </h1>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink-soft); margin:0;">
        Envoyez une invitation par e-mail pour donner accès à l'espace professeur.
      </p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :post }) do |f| %>
      <% invalid = resource.errors[:email].any? %>
      <div style="margin-bottom:20px;">
        <label style="display:block; font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-soft); margin-bottom:8px;">Email du professeur</label>
        <%= f.input_field :email,
              placeholder: "professeur@exemple.com",
              style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem; padding:11px 14px; border:1.5px solid #{invalid ? 'var(--error)' : 'var(--line)'}; border-radius:10px; background:var(--surface); color:var(--ink);" %>
      </div>

      <%= f.button :submit, "Envoyer l'invitation",
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:11px 24px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
    <% end %>

    <div style="display:flex; gap:10px; margin-top:22px; padding-top:18px; border-top:1px solid var(--line-soft);">
      <i class="bi bi-info-circle" style="color:var(--info); font-size:1rem; flex-shrink:0; margin-top:2px;"></i>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-soft); margin:0; line-height:1.5;">
        Le professeur recevra un e-mail avec un lien pour créer son mot de passe et accéder à ses propres activités.
      </p>
    </div>

    <div style="text-align:center; margin-top:16px;">
      <%= link_to "Inviter un étudiant à la place", new_student_invitation_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:var(--ink-faint);" %>
    </div>
  </div>
</div>
