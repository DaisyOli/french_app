<div id="sentence-ordering-<%= sentence_ordering.id %>" style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; margin-bottom:16px;">
  <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px;">
    <div style="display:flex; align-items:center; gap:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--ink-soft);">
      <i class="bi bi-arrows-move" style="color:var(--violet);"></i> Organisation de mots
    </div>
    <%= form_with url: update_order_activity_sentence_ordering_path(@activity, sentence_ordering), method: :patch,
          html: { style: "display:flex; align-items:center; gap:4px;" } do |form| %>
      <%= form.number_field :display_order, min: 1, value: sentence_ordering.display_order,
            title: "Ordre d'affichage",
            style: "width:52px; padding:4px 6px; border:1.5px solid var(--line); border-radius:6px; font-family:'DM Mono',monospace; font-size:0.8rem; text-align:center;" %>
      <%= form.submit "✓", style: "border:1.5px solid var(--brand-bright); background:var(--brand-tint); color:var(--brand-deep); border-radius:6px; padding:4px 9px; cursor:pointer; font-weight:700;" %>
    <% end %>
  </div>

  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.92rem; color:var(--ink); margin-bottom:10px;">
    <strong>Phrase originale :</strong> <%= sentence_ordering.conteúdo %>
  </div>

  <div style="margin-bottom:14px;">
    <div style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-faint); margin-bottom:6px;">Mots à organiser</div>
    <div style="display:flex; flex-wrap:wrap; gap:6px;">
      <% sentence_ordering.sentence_words.order(:correct_position).each do |word| %>
        <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; background:var(--violet-tint); color:var(--violet-deep); border:1.5px solid var(--violet-border); padding:2px 10px; border-radius:20px;"><%= word.word %></span>
      <% end %>
    </div>
  </div>

  <div style="display:flex; gap:8px;">
    <button type="button" class="toggle-form" data-target="form-sentence-ordering-<%= sentence_ordering.id %>" title="Modifier l'exercice"
            style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--brand-bright); background:var(--surface); color:var(--brand-deep); cursor:pointer;">
      <i class="bi bi-pencil"></i>
    </button>
    <%= button_to activity_sentence_ordering_path(@activity, sentence_ordering), method: :delete,
          form: { data: { turbo_confirm: "Supprimer cet exercice d'organisation de mots ?" } },
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; padding:5px 10px; border-radius:8px; border:1.5px solid var(--error-border); background:var(--error-tint); color:var(--error-deep); cursor:pointer;" do %>
      <i class="bi bi-trash"></i>
    <% end %>
  </div>

  <div id="form-sentence-ordering-<%= sentence_ordering.id %>" style="display:none; margin-top:14px; padding-top:14px; border-top:1px solid var(--line-soft);">
    <%= form_with model: sentence_ordering, url: activity_sentence_ordering_path(@activity, sentence_ordering), method: :patch do |form| %>
      <%= form.text_area :conteúdo, rows: 2, placeholder: "Tapez la phrase complète. Ex : Le chat mange la souris.",
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; padding:10px 12px; border:1.5px solid var(--line); border-radius:10px; background:var(--surface); color:var(--ink);" %>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.76rem; color:var(--ink-faint); margin:6px 0 0;">Les mots seront automatiquement séparés pour l'exercice.</p>
      <div style="display:flex; gap:8px; margin-top:10px;">
        <%= form.submit "Enregistrer", style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
        <button type="button" onclick="document.getElementById('form-sentence-ordering-<%= sentence_ordering.id %>').style.display='none'"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:999px; border:1.5px solid var(--line); background:var(--surface); color:var(--ink-soft); cursor:pointer;">
          Annuler
        </button>
      </div>
    <% end %>
  </div>
</div>
