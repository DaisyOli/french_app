<% content_for :head do %>
  <title>Se connecter · Practice-FR</title>
  <style>
    .auth-input:focus { border-color:var(--brand-bright) !important; box-shadow:0 0 0 3px var(--brand-glow) !important; outline:none !important; }
  </style>
<% end %>

<div style="min-height:calc(100vh - 56px); display:flex; align-items:center; justify-content:center; padding:24px 16px;">
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:20px; padding:40px 36px; width:100%; max-width:400px; box-shadow:0 4px 32px rgba(0,0,0,0.07);">

    <%# Logo + espaço (élève ou professeure) %>
    <div style="text-align:center; margin-bottom:28px;">
      <div style="display:inline-flex; align-items:center; gap:10px; margin-bottom:10px;">
        <%= image_tag "practice-fr-logo-mark-color.svg", alt: "Practice-FR", style: "height:38px;" %>
        <div style="text-align:left;">
          <div style="font-family:'Raleway',sans-serif; font-size:1.2rem; font-weight:600; color:var(--brand-deep); line-height:1.1;">Practice-FR</div>
          <div style="font-family:'DM Mono',monospace; font-size:0.58rem; color:var(--ink-faint); letter-spacing:0.06em;">
            <%= resource_name == :student ? "ESPACE ÉLÈVE" : "ESPACE PROFESSEURE" %>
          </div>
        </div>
      </div>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink-soft); margin:0;">
        Bienvenu(e) ! Connectez-vous pour continuer.
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div style="margin-bottom:16px;">
        <%= f.label :email, "E-mail",
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:6px;" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: "votre@email.com",
              class: "auth-input",
              style: "width:100%; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); background:var(--surface); box-sizing:border-box;" %>
      </div>

      <div style="margin-bottom:8px;">
        <%= f.label :password, t('devise.sessions.new.password'),
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:6px;" %>
        <%= f.password_field :password, autocomplete: "current-password",
              placeholder: "••••••••",
              class: "auth-input",
              style: "width:100%; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); background:var(--surface); box-sizing:border-box;" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div style="display:flex; align-items:center; gap:8px; margin-bottom:24px;">
          <%= f.check_box :remember_me, style: "accent-color:var(--brand-bright); width:15px; height:15px;" %>
          <%= f.label :remember_me, t('devise.sessions.new.remember_me'),
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-soft); cursor:pointer;" %>
        </div>
      <% else %>
        <div style="height:24px;"></div>
      <% end %>

      <%= f.submit t('devise.sessions.new.sign_in'),
            style: "width:100%; background:var(--action); color:var(--surface); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:12px; border:none; border-radius:12px; cursor:pointer; margin-bottom:20px; display:block;" %>

    <% end %>

    <% if devise_mapping.recoverable? %>
      <div style="text-align:center; margin-bottom:14px;">
        <%= link_to t('devise.shared.links.forgot_password'), new_password_path(resource_name),
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--brand); text-decoration:none; font-weight:500;" %>
      </div>
    <% end %>

    <%# Passagem entre os dois espaços %>
    <div style="text-align:center; border-top:1px solid var(--line-soft); padding-top:14px;">
      <% if resource_name == :student %>
        <%= link_to "Vous êtes professeure ? →", new_user_session_path,
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--brand); text-decoration:none; font-weight:500;" %>
      <% else %>
        <%= link_to "Vous êtes élève ? →", new_student_session_path,
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--brand); text-decoration:none; font-weight:500;" %>
      <% end %>
    </div>

  </div>
</div>
