<% content_for :head do %>
  <title>Activités · Practice-FR</title>
<% end %>

<div style="max-width:1100px; margin:0 auto; padding:28px 16px 60px;">

  <%# Cabeçalho %>
  <div style="margin-bottom:24px;">
    <h1 style="font-family:'Raleway',sans-serif; font-size:1.5rem; font-weight:700; color:var(--ink); margin:0 0 6px;">
      Toutes les activités
    </h1>
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink-soft); margin:0;">
      <% if @completed_count.to_i > 0 %>
        Déjà <strong style="color:var(--brand);"><%= @completed_count %></strong>
        <%= @completed_count == 1 ? "activité complétée" : "activités complétées" %> — continuez comme ça ! 🎉
      <% else %>
        Choisissez une activité et lancez-vous — un peu chaque jour !
      <% end %>
    </p>
  </div>

  <%# Filtro por nível %>
  <div class="level-filter" data-role="level-filter">
    <button class="level-chip active" data-level="all">Tous</button>
    <% %w[A1 A2 B1 B2 C1 C2].each do |level| %>
      <% count = @activities.count { |a| a.nível == level } %>
      <% next if count.zero? %>
      <button class="level-chip" data-level="<%= level %>">
        <%= level %> · <%= count %>
      </button>
    <% end %>
  </div>

  <% if @activities.any? %>
    <div class="activities-grid">
      <% @activities.each do |activity| %>
        <% completed = @completed_activity_ids.include?(activity.id) %>
        <% completed_record = completed ? @completed_activities.find { |ca| ca.activity_id == activity.id } : nil %>
        <% m = cefr_colors(activity.nível) %>
        <% cover = activity_cover(activity) %>
        <% exercise_count = activity_exercise_count(activity) %>
        <% rating = @student_ratings[activity.id] %>

        <div class="activity-card" data-level="<%= activity.nível %>">

          <%# Capa %>
          <div class="activity-card-cover">
            <% if cover[:type] == :image %>
              <img src="<%= cover[:url] %>" alt="" loading="lazy">
            <% else %>
              <div style="width:100%; height:100%; background:linear-gradient(135deg, <%= m[:bg] %> 0%, color-mix(in srgb, <%= m[:border] %> 20%, transparent) 100%); display:flex; align-items:center; justify-content:center;">
                <i class="bi <%= cover[:icon] %>" style="font-size:2.8rem; color:<%= m[:border] %>; opacity:0.55;"></i>
              </div>
            <% end %>
          </div>

          <%# Conteúdo %>
          <div style="padding:16px 18px; flex:1; display:flex; flex-direction:column;">

            <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:8px;">
              <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; background:<%= m[:bg] %>; color:<%= m[:text] %>; border:1.5px solid <%= m[:border] %>; padding:3px 9px; border-radius:20px;">
                <%= activity.nível %>
              </span>
              <% if completed %>
                <span style="font-size:0.7rem; background:var(--brand-tint); color:var(--brand); border:1px solid var(--brand-bright); border-radius:99px; padding:2px 8px; font-family:'Plus Jakarta Sans',sans-serif; font-weight:700;">
                  ✓ Fait<%= " · #{completed_record.percentage.round}%" if completed_record&.percentage %>
                </span>
              <% end %>
            </div>

            <h3 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:var(--ink); margin:0 0 6px 0; line-height:1.35;">
              <%= activity.título %>
            </h3>

            <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; color:var(--ink-soft); margin:0 0 12px 0; line-height:1.5; flex:1;">
              <%= truncate(activity.texte.presence || activity.texto.presence || "Pratiquez le français avec des exercices interactifs.", length: 80) %>
            </p>

            <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:14px;">
              <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:var(--ink-faint); display:flex; align-items:center; gap:4px;">
                <i class="bi bi-patch-question" style="color:<%= m[:border] %>;"></i>
                <%= exercise_count %> <%= exercise_count == 1 ? 'question' : 'questions' %>
              </span>
              <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:var(--ink-faint); display:flex; align-items:center; gap:4px;">
                <i class="bi bi-clock" style="color:<%= m[:border] %>;"></i>
                ~<%= [5, exercise_count * 2].max %> min
              </span>
              <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:var(--ink-faint); display:flex; align-items:center; gap:4px;">
                <i class="bi bi-bar-chart-line" style="color:<%= m[:border] %>;"></i>
                <%= m[:label] %>
              </span>
              <% if rating %>
                <span style="font-family:'DM Mono',monospace; font-size:0.77rem; font-weight:700; color:var(--action); display:flex; align-items:center; gap:3px;">
                  <i class="bi bi-star-fill" style="font-size:0.68rem;"></i> <%= rating.stars %>
                </span>
              <% end %>
            </div>

            <div style="display:flex; justify-content:flex-end; padding-top:12px; border-top:1px solid var(--line-soft);">
              <%= link_to solve_activity_path(activity),
                    style: "flex-shrink:0; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:10px; text-decoration:none; display:inline-flex; align-items:center; gap:6px; #{completed ? 'background:var(--paper); color:var(--ink-soft); border:1.5px solid var(--line);' : "background:#{m[:border]}; color:var(--surface);"}" do %>
                <% if completed %>
                  <i class="bi bi-arrow-clockwise"></i> Refaire
                <% else %>
                  <i class="bi bi-play-fill"></i> Commencer
                <% end %>
              <% end %>
            </div>

          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%# Empty state — fofura é requisito de produto %>
    <div style="text-align:center; background:var(--brand-mist); border:2px dashed var(--brand-soft); border-radius:18px; padding:48px 20px;">
      <span style="font-size:2.6rem; display:block; margin-bottom:10px;">🥐</span>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; color:var(--ink-soft); font-size:0.92rem; margin:0;">
        <strong style="color:var(--brand-deep);">Aucune activité pour l'instant…</strong><br>
        Votre professeure prépare quelque chose de délicieux. Revenez bientôt !
      </p>
    </div>
  <% end %>

</div>

<%# Filtro por nível — vanilla JS por enquanto (vira Stimulus quando o app ganhar importmap no layout) %>
<script>
  (function() {
    var chips = document.querySelectorAll('[data-role="level-filter"] .level-chip');
    var cards = document.querySelectorAll('.activity-card[data-level]');
    chips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        chips.forEach(function(c) { c.classList.remove('active'); });
        chip.classList.add('active');
        var level = chip.dataset.level;
        cards.forEach(function(card) {
          card.style.display = (level === 'all' || card.dataset.level === level) ? '' : 'none';
        });
      });
    });
  })();
</script>
