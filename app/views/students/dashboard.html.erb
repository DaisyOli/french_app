<% content_for :head do %>
  <title>Tableau de bord · Practice-FR</title>
<% end %>

<div style="max-width:1100px; margin:0 auto; padding:28px 16px 60px;">

  <%# Hero %>
  <div style="margin-bottom:24px;">
    <h1 style="font-family:'Raleway',sans-serif; font-size:1.6rem; font-weight:800; color:var(--brand-deep); margin:0 0 6px;">
      Bienvenue<%= ", #{current_student.name}" if current_student.name.present? %> !
    </h1>
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.92rem; color:var(--ink-soft); margin:0;">
      Prêt à apprendre le français aujourd'hui ?
    </p>
    <% if current_student.professional_type.present? %>
      <% pm = professional_colors(current_student.professional_type) %>
      <div style="display:inline-flex; align-items:center; gap:6px; margin-top:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-soft);">
        <span style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; background:<%= pm[:bg] %>; color:<%= pm[:text] %>; border:1.5px solid <%= pm[:border] %>; padding:1px 8px; border-radius:20px;">
          <%= current_student.professional_type %>
        </span>
        Parcours professionnel reconnu
      </div>
    <% end %>
  </div>

  <%# Grade de 4 métricas %>
  <div class="dash-metrics-grid" style="margin-bottom:24px;">
    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:16px 18px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:var(--ink-faint); margin-bottom:6px;">Séquence</div>
      <div style="display:flex; align-items:baseline; gap:5px;">
        <span style="font-family:'Raleway',sans-serif; font-size:1.7rem; font-weight:800; color:var(--action);"><%= @current_streak %></span>
        <span style="font-size:1.1rem;">🔥</span>
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-soft);">jour<%= @current_streak > 1 ? 's' : '' %> d'affilée</div>
    </div>

    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:16px 18px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:var(--ink-faint); margin-bottom:6px;">Terminées</div>
      <span style="font-family:'Raleway',sans-serif; font-size:1.7rem; font-weight:800; color:var(--brand);"><%= @completed_count %></span>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-soft);">activité<%= @completed_count > 1 ? 's' : '' %></div>
    </div>

    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:16px 18px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:var(--ink-faint); margin-bottom:6px;">Moyenne</div>
      <span style="font-family:'Raleway',sans-serif; font-size:1.7rem; font-weight:800; color:var(--info);"><%= @average_score %>%</span>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-soft);">score moyen</div>
    </div>

    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:16px 18px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:var(--ink-faint); margin-bottom:6px;">Trophée actuel</div>
      <div style="display:flex; align-items:center; gap:6px;">
        <span style="font-size:1.4rem;"><%= @current_trophy[:icon] %></span>
        <span style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:var(--violet);"><%= @current_trophy[:name] %></span>
      </div>
      <% if @next_trophy[:needed] > 0 %>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.74rem; color:var(--ink-faint); margin-top:4px;">
          <%= @next_trophy[:needed] %> jour<%= @next_trophy[:needed] > 1 ? 's' : '' %> pour <%= @next_trophy[:icon] %> <%= @next_trophy[:name] %>
        </div>
      <% else %>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.74rem; color:var(--success); margin-top:4px;">🎉 Niveau maximum</div>
      <% end %>
    </div>
  </div>

  <%# Seção do meio: continuar estudando + progresso por nível %>
  <div class="dash-mid-grid" style="margin-bottom:32px;">

    <%# Card "Continuer" — flex-column pra esticar de verdade até a altura do %>
    <%# card vizinho "Votre progression" (o grid estica os dois por padrão,  %>
    <%# mas sem isso só a linha imagem+texto ganhava altura própria e sobrava %>
    <%# espaço em branco depois dela). %>
    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; overflow:hidden; height:100%; display:flex; flex-direction:column;">
      <div style="padding:12px 16px; border-bottom:1px solid var(--line-soft); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.04em;">
        <%= @next_activity_is_retry ? "Continuer à progresser" : "Continuer" %>
      </div>
      <% if @next_activity %>
        <% m = cefr_colors(@next_activity.nível) %>
        <% cover = activity_cover(@next_activity) %>
        <div style="display:flex; gap:0; flex:1;">
          <div style="width:120px; min-height:120px; flex-shrink:0; overflow:hidden; display:flex; align-items:center; justify-content:center;">
            <% if cover[:type] == :image %>
              <img src="<%= cover[:url] %>" alt="" style="width:100%; height:100%; object-fit:cover; display:block;">
            <% else %>
              <div style="width:100%; height:100%; background:linear-gradient(135deg, <%= m[:bg] %> 0%, color-mix(in srgb, <%= m[:border] %> 20%, transparent) 100%); display:flex; align-items:center; justify-content:center;">
                <i class="bi <%= cover[:icon] %>" style="font-size:2.2rem; color:<%= m[:border] %>; opacity:0.55;"></i>
              </div>
            <% end %>
          </div>
          <div style="flex:1; min-width:0; padding:14px 16px; display:flex; flex-direction:column;">
            <span style="align-self:flex-start; font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; background:<%= m[:bg] %>; color:<%= m[:text] %>; border:1.5px solid <%= m[:border] %>; padding:2px 8px; border-radius:20px; margin-bottom:6px;">
              <%= @next_activity.nível %>
            </span>
            <h3 style="font-family:'Raleway',sans-serif; font-size:0.95rem; font-weight:700; color:var(--ink); margin:0; line-height:1.35;">
              <%= @next_activity.título %>
            </h3>

            <% if (desc = @next_activity.texte.presence || @next_activity.texto.presence) %>
              <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-soft); margin:8px 0 0; line-height:1.5; flex:1;">
                <%= truncate(desc, length: 100) %>
              </p>
            <% else %>
              <div style="flex:1;"></div>
            <% end %>

            <%
              exercise_count = activity_exercise_count(@next_activity)
              estimated_minutes = [5, exercise_count * 2].max
              real_minutes = @next_completed_record&.duration_minutes
              last_note = @next_completed_record&.percentage
            %>
            <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap; margin-top:12px; padding-top:12px; border-top:1px solid var(--line-soft);">
              <div style="display:flex; gap:10px; flex-wrap:wrap; min-width:0;">
                <% if exercise_count > 0 %>
                  <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.76rem; color:var(--ink-faint); display:flex; align-items:center; gap:4px;">
                    <i class="bi bi-patch-question" style="color:<%= m[:border] %>;"></i>
                    <%= exercise_count %> <%= exercise_count == 1 ? 'question' : 'questions' %>
                  </span>
                <% end %>
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.76rem; color:var(--ink-faint); display:flex; align-items:center; gap:4px;">
                  <i class="bi bi-clock" style="color:<%= m[:border] %>;"></i>
                  ~<%= real_minutes || estimated_minutes %> min
                </span>
                <% if last_note %>
                  <span style="font-family:'DM Mono',monospace; font-size:0.76rem; font-weight:700; color:var(--action); display:flex; align-items:center; gap:4px;">
                    <i class="bi bi-award"></i> Note : <%= last_note.round %>%
                  </span>
                <% end %>
              </div>

              <%= link_to solve_activity_path(@next_activity),
                    style: "flex-shrink:0; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:700; padding:8px 16px; border-radius:9px; text-decoration:none; display:inline-flex; align-items:center; gap:6px; background:#{m[:border]}; color:var(--surface);" do %>
                <% if @next_activity_is_retry %>
                  <i class="bi bi-arrow-clockwise"></i> Refaire
                <% else %>
                  <i class="bi bi-play-fill"></i> Commencer
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% else %>
        <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:24px 16px; text-align:center;">
          <span style="font-size:2rem; display:block; margin-bottom:8px;">🥐</span>
          <p style="font-family:'Plus Jakarta Sans',sans-serif; color:var(--ink-soft); font-size:0.88rem; margin:0;">
            Aucune activité disponible pour l'instant.
          </p>
        </div>
      <% end %>
    </div>

    <%# Votre progression — compétences (CO/CE/EE) + nível atual em destaque %>
    <% bl = cefr_colors(@badge_level) %>
    <% badge_completed = @level_progress.find { |lp| lp[:level] == @badge_level }&.dig(:completed) || 0 %>
    <% comp_tip = @competencia_progress.select { |cp| cp[:total].positive? }.min_by { |cp| cp[:pct] } %>
    <% comp_tip = nil if comp_tip && comp_tip[:pct] >= 50 %>
    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:14px 16px;">
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.04em; margin-bottom:14px;">
        Votre progression
      </div>

      <% @competencia_progress.each do |cp| %>
        <% cm = competencia_colors(cp[:competencia]) %>
        <div style="margin-bottom:12px;">
          <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:4px;">
            <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink);">
              <%= cm[:emoji] %> <%= cm[:label] %>
            </span>
            <span style="font-family:'DM Mono',monospace; font-size:0.76rem; font-weight:700; color:var(--ink-soft); flex-shrink:0;">
              <%= cp[:completed] %> de <%= cp[:total] %>
            </span>
          </div>
          <div style="height:6px; background:<%= cm[:bg] %>; border-radius:3px; overflow:hidden;">
            <div style="height:100%; width:<%= cp[:pct] %>%; background:<%= cm[:bar] %>;"></div>
          </div>
          <% if comp_tip && comp_tip[:competencia] == cp[:competencia] %>
            <div class="quiz-suggestion-block" style="margin-top:8px;">
              <span class="dica-label"><i class="bi bi-lightbulb-fill"></i> Astuce</span>
              Essayez des activités de <%= cm[:label] %>
            </div>
          <% end %>
        </div>
      <% end %>

      <div style="height:1px; background:var(--line-soft); margin:14px 0;"></div>

      <%# Nível atual em destaque %>
      <div style="display:flex; align-items:center; gap:14px; margin-bottom:14px;">
        <div style="width:72px; height:72px; border-radius:50%; background:<%= bl[:bg] %>; border:2px solid <%= bl[:border] %>; color:<%= bl[:text] %>; display:flex; align-items:center; justify-content:center; font-family:'Raleway',sans-serif; font-weight:800; font-size:1.3rem; flex-shrink:0;">
          <%= @badge_level %>
        </div>
        <div>
          <div style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:var(--ink-faint);">
            <%= bl[:label] %>
          </div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.7rem; font-weight:800; color:<%= bl[:border] %>; line-height:1.15;">
            <%= badge_completed %>
          </div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.76rem; color:var(--ink-soft);">
            activité<%= badge_completed > 1 ? 's' : '' %> <%= @badge_level %> terminée<%= badge_completed > 1 ? 's' : '' %>
          </div>
        </div>
      </div>

      <div style="display:flex; flex-wrap:wrap; gap:6px;">
        <% @level_progress.each do |lp| %>
          <% active = lp[:level] == @badge_level %>
          <% m = cefr_colors(lp[:level]) %>
          <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; padding:2px 10px; border-radius:20px;
                       <%= active ? "background:#{m[:bar]}; color:var(--surface); border:1.5px solid #{m[:bar]};" : "background:var(--surface); color:var(--ink-faint); border:1.5px solid var(--line);" %>">
            <%= lp[:level] %>
          </span>
        <% end %>
      </div>
    </div>
  </div>

  <%# Vos niveaux — grade clicável de progresso por nível CEFR %>
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:16px 18px;">
    <div style="margin-bottom:14px;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1.05rem; font-weight:700; color:var(--ink); margin:0;">
        Vos niveaux
      </h2>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-soft); margin:2px 0 0;">
        Votre progression, niveau par niveau
      </p>
    </div>

    <div class="dash-level-grid">
      <% @level_progress.each do |lp| %>
        <% m = cefr_colors(lp[:level]) %>
        <% empty = lp[:total].zero? %>
        <% if lp[:locked] %>
          <div style="text-align:center; border:1.5px solid var(--paper-2); border-radius:12px; padding:12px 6px; opacity:0.4; cursor:not-allowed;" title="Niveau non débloqué par votre professeur">
            <div style="background:var(--line-soft); color:var(--ink-faint); border:1.5px solid var(--line); font-family:'DM Mono',monospace; font-size:0.8rem; font-weight:800; width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; margin:0 auto 8px;">
              🔒
            </div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:var(--ink-faint); margin-bottom:8px;"><%= lp[:level] %></div>
            <div style="background:var(--line-soft); border-radius:99px; height:5px; overflow:hidden; margin-bottom:4px;">
              <div style="width:0%; height:100%; border-radius:99px;"></div>
            </div>
            <div style="font-family:'DM Mono',monospace; font-size:0.62rem; color:var(--ink-faint);">bloqué</div>
          </div>
        <% elsif empty %>
          <div style="text-align:center; border:1.5px solid var(--line-soft); border-radius:12px; padding:12px 6px; opacity:0.45; cursor:not-allowed;">
            <div style="background:<%= m[:bg] %>; color:<%= m[:text] %>; border:1.5px solid <%= m[:border] %>; font-family:'DM Mono',monospace; font-size:0.8rem; font-weight:800; width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; margin:0 auto 8px;">
              <%= lp[:level] %>
            </div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:var(--ink); margin-bottom:8px;"><%= m[:label] %></div>
            <div style="background:var(--line-soft); border-radius:99px; height:5px; overflow:hidden; margin-bottom:4px;">
              <div style="width:0%; height:100%; border-radius:99px;"></div>
            </div>
            <div style="font-family:'DM Mono',monospace; font-size:0.62rem; color:var(--ink-faint);">bientôt</div>
          </div>
        <% else %>
          <%= link_to student_activities_path(level: lp[:level]), class: "level-card-link" do %>
            <div class="level-card-inner" style="text-align:center; border:1.5px solid var(--line-soft); border-radius:12px; padding:12px 6px;">
              <div style="background:<%= m[:bg] %>; color:<%= m[:text] %>; border:1.5px solid <%= m[:border] %>; font-family:'DM Mono',monospace; font-size:0.8rem; font-weight:800; width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; margin:0 auto 8px;">
                <%= lp[:level] %>
              </div>
              <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:var(--ink); margin-bottom:8px;"><%= m[:label] %></div>
              <div style="background:var(--line-soft); border-radius:99px; height:5px; overflow:hidden; margin-bottom:4px;">
                <div style="width:<%= lp[:pct] %>%; height:100%; border-radius:99px; background:<%= m[:bar] %>;"></div>
              </div>
              <div style="font-family:'DM Mono',monospace; font-size:0.62rem; color:var(--ink-faint);"><%= lp[:pct] %>%</div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <div style="text-align:center; margin-top:20px;">
      <%= link_to student_activities_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--surface); background:var(--brand); padding:10px 22px; border-radius:10px; text-decoration:none; display:inline-flex; align-items:center; gap:6px;" do %>
        <i class="bi bi-search"></i> Toutes les activités
      <% end %>
    </div>
  </div>

</div>
