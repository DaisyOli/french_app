<% content_for :head do %>
  <title>Inviter un étudiant · Practice-FR</title>
<% end %>

<div style="max-width:480px; margin:0 auto; padding:28px 16px 60px;">
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:16px; padding:28px 26px;">

    <div style="text-align:center; margin-bottom:22px;">
      <div style="width:56px; height:56px; border-radius:50%; background:var(--brand-tint); display:flex; align-items:center; justify-content:center; margin:0 auto 14px;">
        <i class="bi bi-envelope" style="font-size:1.4rem; color:var(--brand-deep);"></i>
      </div>
      <h1 style="font-family:'Raleway',sans-serif; font-size:1.3rem; font-weight:800; color:var(--brand-deep); margin:0 0 6px;">
        Inviter un étudiant
      </h1>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink-soft); margin:0;">
        Envoyez une invitation par e-mail pour rejoindre vos activités.
      </p>
    </div>

    <%# O erro já aparece no banner de flash do topo (layouts/_flash.html.erb) —
        aqui só destaca o campo em vermelho, sem repetir a mensagem duas vezes. %>
    <%= simple_form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :post }) do |f| %>
      <% invalid = resource.errors[:email].any? %>
      <div style="margin-bottom:20px;">
        <label style="display:block; font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-soft); margin-bottom:8px;">Email de l'étudiant</label>
        <%= f.input_field :email,
              placeholder: "eleve@exemple.com",
              style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem; padding:11px 14px; border:1.5px solid #{invalid ? 'var(--error)' : 'var(--line)'}; border-radius:10px; background:var(--surface); color:var(--ink);" %>
      </div>

      <div style="margin-bottom:28px;">
        <label style="display:block; font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-soft); margin-bottom:8px;">Niveau (optionnel)</label>
        <div style="display:flex; flex-wrap:wrap; gap:8px;">
          <% %w[A1 A2 B1 B2 C1 C2].each do |level| %>
            <% m = cefr_colors(level) %>
            <%= f.radio_button :nível, level, id: "student_nivel_#{level}", class: "level-radio" %>
            <label for="student_nivel_<%= level %>" class="level-pill" style="--pill-bg:<%= m[:bg] %>; --pill-text:<%= m[:text] %>; --pill-border:<%= m[:border] %>;">
              <%= level %>
            </label>
          <% end %>
        </div>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-faint); margin:8px 0 0;">
          Définit quelles activités l'étudiant peut voir (ce niveau et en-dessous). Laissez vide pour un accès complet.
        </p>
      </div>

      <div style="margin-bottom:28px;">
        <label style="display:block; font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--ink-soft); margin-bottom:8px;">Parcours professionnel (optionnel)</label>
        <div style="display:flex; flex-wrap:wrap; gap:8px;">
          <% Student::PROFESSIONAL_TYPES.each do |type| %>
            <% m = professional_colors(type) %>
            <%= f.radio_button :professional_type, type, id: "student_professional_type_#{type}", class: "level-radio" %>
            <label for="student_professional_type_<%= type %>" class="level-pill" style="--pill-bg:<%= m[:bg] %>; --pill-text:<%= m[:text] %>; --pill-border:<%= m[:border] %>;">
              <%= type %>
            </label>
          <% end %>
        </div>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-faint); margin:8px 0 0;">
          Pour les étudiants en formation financée (OPCO ou eCPF) — active la génération d'une attestation de formation.
        </p>
      </div>

      <%= f.button :submit, "Envoyer l'invitation",
            style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:11px 24px; border-radius:999px; border:none; background:var(--brand); color:var(--surface); cursor:pointer;" %>
    <% end %>

    <div style="display:flex; gap:10px; margin-top:22px; padding-top:18px; border-top:1px solid var(--line-soft);">
      <i class="bi bi-info-circle" style="color:var(--info); font-size:1rem; flex-shrink:0; margin-top:2px;"></i>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-soft); margin:0; line-height:1.5;">
        Votre étudiant recevra un e-mail avec un lien pour créer son compte et commencer à pratiquer.
      </p>
    </div>
  </div>
</div>
