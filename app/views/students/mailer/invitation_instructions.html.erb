<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invitation à Practice-FR</title>
</head>
<%# E-mail HTML não pode usar var(--token) — clientes de e-mail não suportam
    CSS custom properties. Hex literais copiados de _tokens.scss (paleta
    Bordeaux crème), mesma lógica que os mailers do practice-br já usam. %>
<body style="margin:0; padding:0; background:#F0E9DC; font-family:'Helvetica Neue',Arial,sans-serif;">

  <%# Preheader invisível — aparece no preview do e-mail antes de abrir %>
  <% teacher = @resource.invited_by %>
  <div style="display:none; max-height:0; overflow:hidden; mso-hide:all;">
    <%= teacher&.name.present? ? "#{teacher.name} vous a invité(e) à pratiquer le français sur Practice-FR." : "Vous avez été invité(e) à rejoindre Practice-FR." %>
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#F0E9DC; padding:40px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="560" cellpadding="0" cellspacing="0" style="background:#FFFFFF; border-radius:16px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.08);">

          <%# Cabeçalho %>
          <tr>
            <td style="background:#5C1630; padding:28px 40px; text-align:center;">
              <div style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:1.4rem; font-weight:800; color:#FFFFFF; letter-spacing:-0.01em;">
                Practice<span style="color:#C08A95;">-FR</span>
              </div>
              <div style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.72rem; color:#C08A95; margin-top:4px; letter-spacing:0.05em;">
                APPRENDRE LE FRANÇAIS
              </div>
            </td>
          </tr>

          <%# Corpo %>
          <tr>
            <td style="padding:40px 40px 32px;">

              <h1 style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:1.25rem; font-weight:800; color:#5C1630; margin:0 0 16px; text-align:center;">
                Vous avez été invité(e) sur Practice-FR !
              </h1>

              <% if teacher&.name.present? %>
                <p style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.95rem; color:#2A1B1E; line-height:1.65; margin:0 0 12px;">
                  Bonjour ! <strong><%= teacher.name %></strong> vous a préparé des activités spécialement conçues pour vous aider à progresser en français de manière ludique et efficace.
                </p>
              <% else %>
                <p style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.95rem; color:#2A1B1E; line-height:1.65; margin:0 0 12px;">
                  Bonjour ! Vous avez été invité(e) à rejoindre Practice-FR, une plateforme d'apprentissage du français interactive et amusante.
                </p>
              <% end %>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:28px 0;">
                <tr>
                  <td width="32%" style="text-align:center; padding:14px 6px; background:#F8E7EB; border-radius:10px;">
                    <div style="font-size:1.3rem; margin-bottom:6px;">🎯</div>
                    <div style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.78rem; font-weight:700; color:#5C1630;">Activités interactives</div>
                  </td>
                  <td width="4%">&nbsp;</td>
                  <td width="32%" style="text-align:center; padding:14px 6px; background:#F8E7EB; border-radius:10px;">
                    <div style="font-size:1.3rem; margin-bottom:6px;">🏆</div>
                    <div style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.78rem; font-weight:700; color:#5C1630;">Système de récompenses</div>
                  </td>
                  <td width="4%">&nbsp;</td>
                  <td width="32%" style="text-align:center; padding:14px 6px; background:#F8E7EB; border-radius:10px;">
                    <div style="font-size:1.3rem; margin-bottom:6px;">📈</div>
                    <div style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.78rem; font-weight:700; color:#5C1630;">Suivi des progrès</div>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:28px;">
                <tr>
                  <td align="center">
                    <a href="<%= accept_invitation_url(@resource, invitation_token: @token) %>"
                       style="display:inline-block; background:#C08A28; color:#FFFFFF;
                              font-family:'Helvetica Neue',Arial,sans-serif; font-size:1rem; font-weight:700;
                              padding:15px 40px; border-radius:12px; text-decoration:none;">
                      Créer mon compte et commencer →
                    </a>
                  </td>
                </tr>
              </table>

              <% if @resource.invitation_due_at %>
                <p style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.8rem; color:#6B5458; margin:0 0 12px; text-align:center;">
                  Cette invitation expire le <%= l(@resource.invitation_due_at, format: :long) %>.
                </p>
              <% end %>

              <p style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.8rem; color:#6B5458; line-height:1.55; margin:0; text-align:center;">
                Si vous n'avez pas demandé cette invitation, vous pouvez ignorer cet e-mail en toute sécurité.
              </p>
            </td>
          </tr>

          <%# Rodapé %>
          <tr>
            <td style="background:#F0E9DC; border-top:1px solid #E2D8C8; padding:18px 36px; text-align:center;">
              <p style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.75rem; color:#6B5458; margin:0;">
                Practice-FR · Apprendre le français n'a jamais été aussi amusant !
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
